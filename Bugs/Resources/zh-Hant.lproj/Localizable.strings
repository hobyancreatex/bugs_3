/* Home — articles */
"home.articles_section_title" = "有用的文章";
"home.article.identify.title" = "我們如何辨識昆蟲？";
"home.article.identify.subtitle" = "幫助在野外或照片中區分物種的基本標誌和工具。";
"home.article.habitats.title" = "昆蟲居住的地方";
"home.article.habitats.subtitle" = "從土壤和落葉到花朵和水—您可以安全探索的典型棲息地。";
"home.article.photography.title" = "微距照片無壓力";
"home.article.photography.subtitle" = "光線、距離和耐心：關於拍攝小物體的清晰照片的簡短提示。";
"home.article.identify.block1.title" = "我們首先看什麼";
"home.article.identify.block1.body" = "身體、翅膀、觸角和腿的形狀往往一眼就能縮小昆蟲的目數。顏色圖案有所幫助，但它們因物種而異——將它們與體型、姿勢和行為結合。如果可能，請記下您在哪裡看到昆蟲：寄主植物、土壤表面或水邊都可以添加背景資訊。";
"home.article.identify.block2.title" = "來自一張照片";
"home.article.identify.block2.body" = "清晰、光線充足的影像每次都會擊敗模糊的影像。拍攝俯視圖，如果可以的話，請拍攝側面輪廓。當尺寸很重要時，請包括比例感（硬幣或手指）。當標記很微妙或隱藏在折疊機翼下時，多個角度可以減少猜測。";
"home.article.habitats.block1.title" = "棲息地的層次";
"home.article.habitats.block1.body" = "昆蟲利用垂直空間：樹冠、林下、落葉層、樹皮縫隙和土壤。轉動一根木頭或舉起一塊石頭，可以揭示與陽光下的花頭不同的群落。緩慢移動並更換覆蓋物，以保持微生境完好無損。";
"home.article.habitats.block2.title" = "水和邊緣";
"home.article.habitats.block2.body" = "池塘、溪流和潮濕的草地上棲息著蜻蜓、豆娘和許多甲蟲等專家。陸地和水域之間的邊界——蘆葦、泥濘的河岸——往往是最富饒的地區。先遠距離觀察，以免打擾休息的昆蟲。";
"home.article.photography.block1.title" = "光與距離";
"home.article.photography.block1.body" = "漫射日光或開放式陰影可提供均勻的照明，而不會產生刺眼的陰影。距離足夠近以填充整個框架，但避免將自己的陰影投射到拍攝對像上。小反光板或白卡可以提升花朵或樹皮深處的細節。";
"home.article.photography.block2.title" = "耐心和尊重";
"home.article.photography.block2.body" = "讓昆蟲安定下來，而不是追逐它們。突發模式有助於處理不穩定的傳單。如果您使用閃光燈，請保持簡短，並且切勿將其直接對準附近脊椎動物的眼睛。完成後，讓棲息地保持原樣。";

