/* Home — articles */
"home.articles_section_title" = "مفید مضامین";
"home.article.identify.title" = "ہم کیڑوں کی شناخت کیسے کریں؟";
"home.article.identify.subtitle" = "بنیادی نشانیاں اور ٹولز جو انواع کو کھیت میں یا تصویر سے الگ بتانے میں مدد کرتے ہیں۔";
"home.article.habitats.title" = "جہاں کیڑے مکوڑے رہتے ہیں۔";
"home.article.habitats.subtitle" = "مٹی اور پتوں کے گندگی سے لے کر پھولوں اور پانی تک - عام رہائش گاہوں کو آپ محفوظ طریقے سے تلاش کر سکتے ہیں۔";
"home.article.photography.title" = "دباؤ کے بغیر میکرو فوٹو";
"home.article.photography.subtitle" = "روشنی، فاصلہ، اور صبر: چھوٹے مضامین کی واضح تصویروں کے لیے مختصر تجاویز۔";
"home.article.identify.block1.title" = "جو ہم پہلے دیکھتے ہیں۔";
"home.article.identify.block1.body" = "جسم کی شکل، پنکھ، اینٹینا، اور ٹانگیں اکثر ایک نظر میں کیڑوں کی ترتیب کو کم کر دیتی ہیں۔ رنگ کے نمونے مدد کرتے ہیں، لیکن وہ انواع کے اندر مختلف ہوتے ہیں — انہیں سائز، کرنسی اور رویے کے ساتھ جوڑیں۔ جب ممکن ہو، نوٹ کریں کہ آپ نے کیڑے کو کہاں دیکھا: میزبان پودا، مٹی کی سطح، یا پانی کے کنارے سبھی سیاق و سباق کو شامل کرتے ہیں۔";
"home.article.identify.block2.title" = "ایک تصویر سے";
"home.article.identify.block2.body" = "ایک تیز، اچھی طرح سے روشن تصویر ہر بار ایک دھندلی تصویر کو شکست دیتی ہے۔ اوپر والے منظر کو کیپچر کریں اور، اگر ہو سکے تو، سائیڈ پروفائل کو۔ جب سائز اہمیت رکھتا ہو تو پیمانے کا احساس (ایک سکہ یا آپ کی انگلی) شامل کریں۔ جب نشانات لطیف ہوتے ہیں یا فولڈ پروں کے نیچے چھپے ہوتے ہیں تو کئی زاویے اندازے کو کم کرتے ہیں۔";
"home.article.habitats.block1.title" = "رہائش گاہ کی تہہ";
"home.article.habitats.block1.body" = "کیڑے عمودی جگہ کا استعمال کرتے ہیں: چھتری، زیریں، پتوں کی گندگی، چھال کے دراڑوں، اور مٹی۔ لاگ موڑنا یا پتھر اٹھانا پوری دھوپ میں پھولوں کے سر سے مختلف کمیونٹی کو ظاہر کرتا ہے۔ آہستہ آہستہ حرکت کریں اور کور کو تبدیل کریں تاکہ مائیکرو ہیبیٹیٹس برقرار رہیں۔";
"home.article.habitats.block2.title" = "پانی اور کنارے";
"home.article.habitats.block2.body" = "تالاب، نہریں، اور نم گھاس کے میدان ماہرین کی میزبانی کرتے ہیں جیسے ڈریگن فلائیز، ڈیم فلائیز، اور بہت سے بیٹل۔ زمین اور پانی کے درمیان سرحد - سرکنڈے، کیچڑ والے کنارے - اکثر امیر ترین زون ہوتا ہے۔ آرام کرنے والے کیڑوں کو پریشان کرنے سے بچنے کے لیے پہلے دور سے مشاہدہ کریں۔";
"home.article.photography.block1.title" = "روشنی اور فاصلہ";
"home.article.photography.block1.body" = "پھیلا ہوا دن کی روشنی یا کھلا سایہ سخت سائے کے بغیر بھی روشنی دیتا ہے۔ فریم کو بھرنے کے لیے کافی قریب پہنچیں، لیکن موضوع پر اپنا سایہ ڈالنے سے گریز کریں۔ ایک چھوٹا ریفلیکٹر یا سفید کارڈ پھولوں یا چھال کی گہرائیوں میں تفصیل اٹھا سکتا ہے۔";
"home.article.photography.block2.title" = "صبر اور احترام";
"home.article.photography.block2.body" = "کیڑوں کو ان کا پیچھا کرنے کے بجائے آباد ہونے دیں۔ برسٹ موڈ سکیٹش فلائیرز کے ساتھ مدد کرتا ہے۔ اگر آپ فلیش کا استعمال کرتے ہیں تو سیشنز کو مختصر رکھیں اور اسے کبھی بھی قریبی ریڑھ کی ہڈیوں کی آنکھوں میں براہ راست اشارہ نہ کریں۔ جب آپ کام کر لیں تو رہائش گاہ کو جیسا کہ آپ نے پایا اسے چھوڑ دیں۔";

