"insect.detail.mock.description" = "مغربی شہد کی مکھی (Apis mellifera) زراعت اور جنگلی ماحولیاتی نظام میں سب سے اہم منظم جرگوں میں سے ہے۔ یورپ، مغربی ایشیا اور افریقہ سے تعلق رکھنے والے، اسے شہد کی مکھیوں کے پالنے والوں نے شہد کی پیداوار اور فصلوں کے جرگن کے لیے دنیا بھر میں پھیلایا ہے۔\n\nکالونی ایک سپر آرگنزم ہے: ایک ہی زرخیز ملکہ انڈے دیتی ہے، جب کہ ہزاروں خواتین ورکرز چارہ دیتی ہیں، لاروا پالتی ہیں، کنگھی بناتی ہیں اور گھونسلے کا دفاع کرتی ہیں۔ مرد ڈرون موسمی طور پر ظاہر ہوتے ہیں اور دوسری کالونیوں کی ملکہ کے ساتھ مل جاتے ہیں۔ ورکرز ویگل ڈانس کے ذریعے خوراک کے امیر ذرائع تک سمت اور فاصلے کا پتہ لگاتے ہیں اور ٹچ اور فیرومونز کے ذریعے معلومات کا اشتراک کرتے ہیں۔\n\nچرانے والے پودوں کی بہت سی انواع کا دورہ کرتے ہیں، جب وہ حرکت کرتے ہیں تو جرگ منتقل کرتے ہیں۔ یہ رویہ حیاتیاتی تنوع اور کھانے کی فصلوں کو سپورٹ کرتا ہے - باغات اور بیریوں سے لے کر تیل کے بیجوں اور خربوزوں تک۔ شہد کی مکھیاں پالنے والے شہد کی کٹائی کو کالونی کی صحت کے ساتھ متوازن کرنے کے لیے چھتے کا انتظام کرتے ہیں، کیڑوں، بیماریوں اور غذائیت کے دباؤ کی نگرانی کرتے ہیں۔\n\nاگرچہ عام طور پر پھولوں پر نرم مزاج ہوتے ہیں، شہد کی مکھیاں اپنے چھتے کا دفاع کرتی ہیں اگر انہیں خطرہ محسوس ہوتا ہے۔ ان کے اشارے کو سمجھنے سے ڈنک کم ہو جاتے ہیں۔ رہائش گاہ کا نقصان، کیڑے مار ادویات، پیتھوجینز، اور موسمیاتی تبدیلیاں جنگلی اور منظم آبادی دونوں کو چیلنج کرتی ہیں۔ پھولوں کے وسائل کی حفاظت اور محتاط انتظام کو اپنانے سے مستقبل کے موسموں کے لیے ان قابل ذکر کیڑوں کو برقرار رکھنے میں مدد ملتی ہے۔";
