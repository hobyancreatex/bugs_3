/* Home — articles */
"home.articles_section_title" = "Χρήσιμα άρθρα";
"home.article.identify.title" = "Πώς αναγνωρίζουμε τα έντομα;";
"home.article.identify.subtitle" = "Βασικές πινακίδες και εργαλεία που βοηθούν να ξεχωρίσετε τα είδη στο χωράφι ή από μια φωτογραφία.";
"home.article.habitats.title" = "Όπου ζουν τα έντομα";
"home.article.habitats.subtitle" = "Από χώμα και απορρίμματα φύλλων μέχρι λουλούδια και νερό — τυπικοί βιότοποι που μπορείτε να εξερευνήσετε με ασφάλεια.";
"home.article.photography.title" = "Μακρο φωτογραφίες χωρίς άγχος";
"home.article.photography.subtitle" = "Φως, απόσταση και υπομονή: σύντομες συμβουλές για πιο καθαρές εικόνες μικρών θεμάτων.";
"home.article.identify.block1.title" = "Αυτό που κοιτάμε αρχικά";
"home.article.identify.block1.body" = "Το σχήμα του σώματος, τα φτερά, οι κεραίες και τα πόδια συχνά περιορίζουν τη σειρά των εντόμων με μια ματιά. Τα χρωματικά μοτίβα βοηθούν, αλλά ποικίλλουν ανάλογα με το είδος - συνδυάστε τα με το μέγεθος, τη στάση και τη συμπεριφορά. Όταν είναι δυνατόν, σημειώστε πού είδατε το έντομο: το φυτό ξενιστή, η επιφάνεια του εδάφους ή η άκρη του νερού προσθέτουν περιεχόμενο.";
"home.article.identify.block2.title" = "Από φωτογραφία";
"home.article.identify.block2.body" = "Μια ευκρινής, καλά φωτισμένη εικόνα ξεπερνά μια θολή κάθε φορά. Καταγράψτε την κάτοψη και, αν μπορείτε, το πλευρικό προφίλ. Συμπεριλάβετε την αίσθηση της κλίμακας (ένα νόμισμα ή το δάχτυλό σας) όταν το μέγεθος έχει σημασία. Πολλές γωνίες μειώνουν τις εικασίες όταν τα σημάδια είναι διακριτικά ή κρύβονται κάτω από διπλωμένα φτερά.";
"home.article.habitats.block1.title" = "Στρώματα ενός οικοτόπου";
"home.article.habitats.block1.body" = "Τα έντομα χρησιμοποιούν κάθετο χώρο: θόλο, κάτω όροφο, απορρίμματα φύλλων, σχισμές φλοιού και χώμα. Γυρίζοντας ένα κούτσουρο ή σηκώνοντας μια πέτρα αποκαλύπτεται μια διαφορετική κοινότητα από ένα κεφάλι λουλουδιών στον ήλιο. Μετακινηθείτε αργά και αντικαταστήστε τα καλύμματα ώστε οι μικροβιότοποι να παραμείνουν άθικτοι.";
"home.article.habitats.block2.title" = "Νερό και άκρες";
"home.article.habitats.block2.body" = "Λίμνες, ρυάκια και υγρά λιβάδια φιλοξενούν ειδικούς όπως λιβελλούλες, νταούλια και πολλά σκαθάρια. Τα σύνορα μεταξύ ξηράς και νερού - καλάμια, λασπώδεις όχθες - είναι συχνά η πιο πλούσια ζώνη. Παρατηρήστε πρώτα από απόσταση για να αποφύγετε ενοχλητικά έντομα που ξεκουράζονται.";
"home.article.photography.block1.title" = "Φως και απόσταση";
"home.article.photography.block1.body" = "Το διάχυτο φως της ημέρας ή η ανοιχτή σκιά δίνουν ομοιόμορφο φωτισμό χωρίς σκληρές σκιές. Πλησιάστε αρκετά για να γεμίσετε το πλαίσιο, αλλά αποφύγετε να ρίξετε τη δική σας σκιά στο θέμα. Ένας μικρός ανακλαστήρας ή μια λευκή κάρτα μπορεί να ανυψώσει τη λεπτομέρεια σε βαθιές εσοχές λουλουδιών ή φλοιού.";
"home.article.photography.block2.title" = "Υπομονή και σεβασμός";
"home.article.photography.block2.body" = "Αφήστε τα έντομα να εγκατασταθούν αντί να τα κυνηγήσετε. Η λειτουργία ριπής βοηθάει με τα φυλλομετρικά φυλλάδια. Εάν χρησιμοποιείτε φλας, κρατήστε τις συνεδρίες σύντομες και μην το στρέφετε ποτέ απευθείας στα μάτια των σπονδυλωτών που βρίσκονται κοντά. Όταν τελειώσετε, αφήστε τον βιότοπο όπως τον βρήκατε.";

