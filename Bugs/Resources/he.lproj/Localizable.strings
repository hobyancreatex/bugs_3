/* Home — articles */
"home.articles_section_title" = "מאמרים שימושיים";
"home.article.identify.title" = "כיצד נזהה חרקים?";
"home.article.identify.subtitle" = "סימנים וכלים בסיסיים שעוזרים להבדיל בין מינים בשטח או מתמונה.";
"home.article.habitats.title" = "היכן שחרקים חיים";
"home.article.habitats.subtitle" = "החל מאדמה ועלים ועד פרחים ומים - בתי גידול אופייניים שתוכלו לחקור בבטחה.";
"home.article.photography.title" = "תמונות מאקרו ללא לחץ";
"home.article.photography.subtitle" = "אור, מרחק וסבלנות: עצות קצרות לתמונות ברורות יותר של נושאים קטנים.";
"home.article.identify.block1.title" = "מה שאנחנו מסתכלים עליו קודם";
"home.article.identify.block1.body" = "צורת הגוף, הכנפיים, האנטנות והרגליים מצמצמים לעתים קרובות את סדר החרקים במבט חטוף. דפוסי צבע עוזרים, אבל הם משתנים בין המינים - משלבים אותם עם גודל, יציבה והתנהגות. במידת האפשר, שים לב היכן ראית את החרק: צמח מארח, פני האדמה או קצה המים מוסיפים הקשר.";
"home.article.identify.block2.title" = "מתוך תמונה";
"home.article.identify.block2.body" = "תמונה חדה ומוארת היטב מנצחת תמונה מטושטשת בכל פעם. צלם את התצוגה העליונה, ואם אתה יכול, את פרופיל הצד. כלול תחושת קנה מידה (מטבע או אצבע שלך) כאשר הגודל חשוב. כמה זוויות מפחיתות ניחושים כאשר הסימונים עדינים או מוסתרים מתחת לכנפיים מקופלות.";
"home.article.habitats.block1.title" = "שכבות של בית גידול";
"home.article.habitats.block1.body" = "חרקים משתמשים בחלל אנכי: חופה, תת קרקע, פסולת עלים, חריצי קליפה ואדמה. הפיכת בול עץ או הרמת אבן חושפת קהילה אחרת מאשר ראש פרח בשמש מלאה. זזו באיטיות והחליפו כיסויים כך שבתי גידול יישארו שלמים.";
"home.article.habitats.block2.title" = "מים וקצוות";
"home.article.habitats.block2.body" = "בריכות, נחלים וכרי דשא לחים מארחים מומחים כמו שפיריות, דפנות וחיפושיות רבות. הגבול בין אדמה למים - קנים, גדות בוציות - הוא לרוב האזור העשיר ביותר. תחילה התבוננו מרחוק כדי להימנע מחרקים נחים.";
"home.article.photography.block1.title" = "אור ומרחק";
"home.article.photography.block1.body" = "אור יום מפוזר או גוון פתוח מעניק תאורה אחידה ללא צללים קשים. התקרב מספיק כדי למלא את הפריים, אך הימנע מהטלת צל משלך על הנושא. רפלקטור קטן או כרטיס לבן יכולים להרים פרטים בשקעים עמוקים של פרחים או קליפה.";
"home.article.photography.block2.title" = "סבלנות וכבוד";
"home.article.photography.block2.body" = "תן לחרקים להתיישב במקום לרדוף אחריהם. מצב פרץ עוזר עם עלונים עצבניים. אם אתה משתמש בפלאש, הקפד על הפעלות קצרות ולעולם אל תכוון אותו ישירות לעיניים של חולייתנים בקרבת מקום. כשתסיים, עזוב את בית הגידול כפי שמצאת אותו.";

