/* Home — articles */
"home.articles_section_title" = "Articole utile";
"home.article.identify.title" = "Cum identificăm insectele?";
"home.article.identify.subtitle" = "Semne și instrumente de bază care ajută la deosebirea speciilor pe câmp sau dintr-o fotografie.";
"home.article.habitats.title" = "Unde trăiesc insectele";
"home.article.habitats.subtitle" = "De la sol și așternut de frunze până la flori și apă - habitate tipice pe care le puteți explora în siguranță.";
"home.article.photography.title" = "Fotografii macro fără stres";
"home.article.photography.subtitle" = "Lumină, distanță și răbdare: sfaturi scurte pentru imagini mai clare ale subiecților mici.";
"home.article.identify.block1.title" = "La ce ne uităm mai întâi";
"home.article.identify.block1.body" = "Forma corpului, aripile, antenele și picioarele îngustează adesea ordinea insectelor dintr-o privire. Modelele de culoare ajută, dar variază în funcție de specie - combină-le cu dimensiunea, postura și comportamentul. Când este posibil, rețineți unde ați văzut insecta: planta gazdă, suprafața solului sau marginea apei, toate adaugă context.";
"home.article.identify.block2.title" = "Dintr-o fotografie";
"home.article.identify.block2.body" = "O imagine clară, bine luminată o bate de fiecare dată pe una neclară. Capturați vederea de sus și, dacă puteți, profilul lateral. Includeți un sentiment de scară (o monedă sau un deget) atunci când dimensiunea contează. Mai multe unghiuri reduc presupunerile atunci când marcajele sunt subtile sau ascunse sub aripile îndoite.";
"home.article.habitats.block1.title" = "Straturi ale unui habitat";
"home.article.habitats.block1.body" = "Insectele folosesc spațiul vertical: baldachin, subteras, așternut de frunze, crăpături din scoarță și sol. Întoarcerea unui buștean sau ridicarea unei pietre dezvăluie o comunitate diferită de un cap de floare în plin soare. Deplasați-vă încet și înlocuiți capacele astfel încât microhabitatele să rămână intacte.";
"home.article.habitats.block2.title" = "Apă și margini";
"home.article.habitats.block2.body" = "Iazurile, pâraiele și pajiștile umede găzduiesc specialiști, cum ar fi libelule, damerici și mulți gândaci. Granița dintre pământ și apă - stuf, maluri noroioase - este adesea cea mai bogată zonă. Observați mai întâi de la distanță pentru a evita deranjarea insectelor care se odihnesc.";
"home.article.photography.block1.title" = "Lumina si distanta";
"home.article.photography.block1.body" = "Lumina difuză a zilei sau umbra deschisă oferă o iluminare uniformă, fără umbre dure. Apropiați-vă suficient pentru a umple cadrul, dar evitați să vă aruncați propria umbră peste subiect. Un reflector mic sau un card alb poate ridica detaliile în adâncituri de flori sau scoarță.";
"home.article.photography.block2.title" = "Răbdare și respect";
"home.article.photography.block2.body" = "Lăsați insectele să se așeze în loc să le urmăriți. Modul Burst ajută la fluturași supărați. Dacă utilizați blițul, păstrați sesiunile scurte și nu îl îndreptați niciodată direct în ochii vertebratelor din apropiere. Când ați terminat, lăsați habitatul așa cum l-ați găsit.";

