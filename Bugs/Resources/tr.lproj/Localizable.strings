/* Home — articles */
"home.articles_section_title" = "Faydalı makaleler";
"home.article.identify.title" = "Böcekleri nasıl tespit ederiz?";
"home.article.identify.subtitle" = "Türleri tarlada veya bir fotoğraftan ayırmaya yardımcı olan temel işaretler ve araçlar.";
"home.article.habitats.title" = "Böceklerin yaşadığı yer";
"home.article.habitats.subtitle" = "Toprak ve yaprak döküntülerinden çiçeklere ve suya kadar, güvenle keşfedebileceğiniz tipik yaşam alanları.";
"home.article.photography.title" = "Stressiz makro fotoğraflar";
"home.article.photography.subtitle" = "Işık, mesafe ve sabır: küçük konuların daha net resimleri için kısa ipuçları.";
"home.article.identify.block1.title" = "İlk olarak neye bakıyoruz";
"home.article.identify.block1.body" = "Vücudun şekli, kanatları, antenleri ve bacakları genellikle bir bakışta böceklerin sırasını daraltır. Renk desenleri yardımcı olur, ancak türler arasında farklılık gösterirler; bunları boyut, duruş ve davranışla birleştirirler. Mümkün olduğunda böceği nerede gördüğünüzü not edin: konakçı bitki, toprak yüzeyi veya su kenarı, bunların hepsi bağlam katar.";
"home.article.identify.block2.title" = "Bir fotoğraftan";
"home.article.identify.block2.body" = "Keskin, iyi aydınlatılmış bir görüntü her zaman bulanık olanı yener. Üst görünümü ve mümkünse yan profili yakalayın. Boyut önemli olduğunda ölçek hissini (bir bozuk para veya parmağınız) ekleyin. İşaretler ince olduğunda veya katlanmış kanatların altında gizlendiğinde, çeşitli açılar tahminleri azaltır.";
"home.article.habitats.block1.title" = "Bir habitatın katmanları";
"home.article.habitats.block1.body" = "Böcekler dikey alanı kullanır: gölgelik, alt kat, yaprak döküntüsü, ağaç kabuğu yarıkları ve toprak. Bir kütüğü çevirmek veya bir taşı kaldırmak, tam güneş altındaki bir çiçek başından farklı bir topluluğu ortaya çıkarır. Mikro yaşam alanlarının bozulmadan kalması için yavaş hareket edin ve örtüleri değiştirin.";
"home.article.habitats.block2.title" = "Su ve kenarlar";
"home.article.habitats.block2.body" = "Göletler, dereler ve nemli çayırlar yusufçuk, kızböcekleri ve birçok böcek gibi uzmanlara ev sahipliği yapar. Kara ve su arasındaki sınır (sazlar, çamurlu kıyılar) genellikle en zengin bölgedir. Dinlenen böcekleri rahatsız etmekten kaçınmak için önce uzaktan gözlemleyin.";
"home.article.photography.block1.title" = "Işık ve mesafe";
"home.article.photography.block1.body" = "Dağınık gün ışığı veya açık gölge, sert gölgeler olmadan eşit aydınlatma sağlar. Çerçeveyi dolduracak kadar yaklaşın ancak nesnenin üzerine kendi gölgenizi düşürmekten kaçının. Küçük bir reflektör veya beyaz kart, çiçek veya ağaç kabuğunun derin girintilerindeki ayrıntıları ortaya çıkarabilir.";
"home.article.photography.block2.title" = "Sabır ve saygı";
"home.article.photography.block2.body" = "Böcekleri kovalamak yerine yerleşmelerine izin verin. Seri çekim modu, ürkek uçuşlara yardımcı olur. Flaş kullanıyorsanız, oturumları kısa tutun ve asla doğrudan yakındaki omurgalıların gözlerine doğrultmayın. İşiniz bittiğinde yaşam alanını bulduğunuz gibi bırakın.";

