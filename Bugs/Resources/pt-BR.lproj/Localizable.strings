/* Home — articles */
"home.articles_section_title" = "Artigos úteis";
"home.article.identify.title" = "Como identificamos insetos?";
"home.article.identify.subtitle" = "Sinais e ferramentas básicas que ajudam a diferenciar as espécies no campo ou em uma foto.";
"home.article.habitats.title" = "Onde vivem os insetos";
"home.article.habitats.subtitle" = "Desde solo e serapilheira até flores e água – habitats típicos que você pode explorar com segurança.";
"home.article.photography.title" = "Fotos macro sem estresse";
"home.article.photography.subtitle" = "Luz, distância e paciência: dicas curtas para fotos mais nítidas de objetos pequenos.";
"home.article.identify.block1.title" = "O que olhamos primeiro";
"home.article.identify.block1.body" = "O formato do corpo, asas, antenas e pernas geralmente restringem a ordem dos insetos à primeira vista. Os padrões de cores ajudam, mas variam dentro da espécie – combine-os com tamanho, postura e comportamento. Quando possível, anote onde você viu o inseto: planta hospedeira, superfície do solo ou borda da água, tudo isso adiciona contexto.";
"home.article.identify.block2.title" = "De uma foto";
"home.article.identify.block2.body" = "Uma imagem nítida e bem iluminada sempre supera uma imagem borrada. Capture a vista superior e, se puder, o perfil lateral. Inclua um senso de escala (uma moeda ou seu dedo) quando o tamanho for importante. Vários ângulos reduzem as suposições quando as marcações são sutis ou escondidas sob as asas dobradas.";
"home.article.habitats.block1.title" = "Camadas de um habitat";
"home.article.habitats.block1.body" = "Os insetos usam o espaço vertical: copa, sub-bosque, serapilheira, fendas na casca e solo. Virar um tronco ou levantar uma pedra revela uma comunidade diferente daquela de uma flor em pleno sol. Mova-se lentamente e recoloque as tampas para que os microhabitats permaneçam intactos.";
"home.article.habitats.block2.title" = "Água e bordas";
"home.article.habitats.block2.body" = "Lagoas, riachos e prados úmidos hospedam especialistas como libélulas, libelinhas e muitos besouros. A fronteira entre a terra e a água – juncos, margens lamacentas – é frequentemente a zona mais rica. Observe primeiro à distância para evitar perturbar os insetos em repouso.";
"home.article.photography.block1.title" = "Luz e distância";
"home.article.photography.block1.body" = "A luz diurna difusa ou a sombra aberta proporcionam uma iluminação uniforme, sem sombras fortes. Aproxime-se o suficiente para preencher o quadro, mas evite projetar sua própria sombra no objeto. Um pequeno refletor ou cartão branco pode destacar detalhes em recessos profundos de flores ou cascas.";
"home.article.photography.block2.title" = "Paciência e respeito";
"home.article.photography.block2.body" = "Deixe os insetos se estabelecerem em vez de persegui-los. O modo Burst ajuda com voadores nervosos. Se você usar flash, mantenha as sessões curtas e nunca aponte-o diretamente para os olhos dos vertebrados próximos. Quando terminar, deixe o habitat como o encontrou.";

