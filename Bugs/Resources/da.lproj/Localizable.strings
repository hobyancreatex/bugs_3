/* Home — articles */
"home.articles_section_title" = "Nyttige artikler";
"home.article.identify.title" = "Hvordan identificerer vi insekter?";
"home.article.identify.subtitle" = "Grundlæggende tegn og værktøjer, der hjælper med at skelne arter i marken eller fra et foto.";
"home.article.habitats.title" = "Hvor insekter lever";
"home.article.habitats.subtitle" = "Fra jord og bladaffald til blomster og vand - typiske levesteder, du kan udforske sikkert.";
"home.article.photography.title" = "Makrobilleder uden stress";
"home.article.photography.subtitle" = "Lys, afstand og tålmodighed: korte tips til klarere billeder af små motiver.";
"home.article.identify.block1.title" = "Hvad vi ser på først";
"home.article.identify.block1.body" = "Kroppens form, vinger, antenner og ben indsnævrer ofte rækkefølgen af insekter ved et blik. Farvemønstre hjælper, men de varierer inden for arter - kombiner dem med størrelse, kropsholdning og adfærd. Når det er muligt, skal du notere, hvor du så insektet: værtsplante, jordoverflade eller vandkant tilføjer alle sammenhænge.";
"home.article.identify.block2.title" = "Fra et foto";
"home.article.identify.block2.body" = "Et skarpt, godt oplyst billede slår et sløret hver gang. Fang topvisningen og, hvis du kan, sideprofilen. Inkluder en følelse af skala (en mønt eller din finger), når størrelsen betyder noget. Flere vinkler reducerer gætværk, når markeringer er subtile eller skjult under foldede vinger.";
"home.article.habitats.block1.title" = "Lag af et habitat";
"home.article.habitats.block1.body" = "Insekter bruger lodret plads: baldakin, underhus, løvstrøelse, bark sprækker og jord. At dreje en træstamme eller løfte en sten afslører et andet fællesskab end et blomsterhoved i fuld sol. Bevæg dig langsomt og udskift dæksler, så mikrohabitater forbliver intakte.";
"home.article.habitats.block2.title" = "Vand og kanter";
"home.article.habitats.block2.body" = "Damme, vandløb og fugtige enge er vært for specialister som guldsmede, vandmøller og mange biller. Grænsen mellem land og vand - siv, mudrede bredder - er ofte den rigeste zone. Observer først på afstand for at undgå at forstyrre hvilende insekter.";
"home.article.photography.block1.title" = "Lys og afstand";
"home.article.photography.block1.body" = "Diffust dagslys eller åben skygge giver jævn belysning uden hårde skygger. Kom tæt nok på til at fylde rammen, men undgå at kaste din egen skygge hen over motivet. En lille refleks eller hvidt kort kan løfte detaljer i dybe fordybninger af blomster eller bark.";
"home.article.photography.block2.title" = "Tålmodighed og respekt";
"home.article.photography.block2.body" = "Lad insekter slå sig ned i stedet for at jage dem. Burst-tilstand hjælper med skæve flyers. Hvis du bruger blitz, skal du holde sessionerne korte og aldrig rette den direkte ind i øjnene på hvirveldyr i nærheden. Når du er færdig, skal du forlade habitatet, som du fandt det.";

