/* Home — articles */
"home.articles_section_title" = "Artikel yang bermanfaat";
"home.article.identify.title" = "Bagaimana kita mengidentifikasi serangga?";
"home.article.identify.subtitle" = "Tanda dan alat dasar yang membantu membedakan spesies di lapangan atau dari foto.";
"home.article.habitats.title" = "Tempat tinggal serangga";
"home.article.habitats.subtitle" = "Dari tanah dan serasah daun hingga bunga dan air — habitat khas yang dapat Anda jelajahi dengan aman.";
"home.article.photography.title" = "Foto makro tanpa stres";
"home.article.photography.subtitle" = "Cahaya, jarak, dan kesabaran: tip singkat untuk gambar subjek kecil yang lebih jelas.";
"home.article.identify.block1.title" = "Apa yang kita lihat pertama kali";
"home.article.identify.block1.body" = "Bentuk tubuh, sayap, antena, dan kaki sering kali mempersempit urutan serangga secara sekilas. Pola warna memang membantu, tetapi polanya berbeda-beda pada setiap spesies — dipadukan dengan ukuran, postur, dan perilaku. Jika memungkinkan, catat di mana Anda melihat serangga tersebut: tanaman inang, permukaan tanah, atau tepi air, semuanya menambah konteks.";
"home.article.identify.block2.title" = "Dari sebuah foto";
"home.article.identify.block2.body" = "Gambar yang tajam dan terang selalu mengalahkan gambar buram. Tangkap tampilan atas dan, jika bisa, profil samping. Sertakan skala (koin atau jari Anda) ketika ukuran penting. Beberapa sudut mengurangi dugaan ketika tanda tidak kentara atau tersembunyi di bawah sayap terlipat.";
"home.article.habitats.block1.title" = "Lapisan suatu habitat";
"home.article.habitats.block1.body" = "Serangga memanfaatkan ruang vertikal: kanopi, tumbuhan bawah, serasah daun, celah kulit kayu, dan tanah. Membalik batang kayu atau mengangkat batu memperlihatkan komunitas yang berbeda dari kepala bunga di bawah sinar matahari penuh. Bergerak perlahan dan ganti penutup agar habitat mikro tetap utuh.";
"home.article.habitats.block2.title" = "Air dan tepiannya";
"home.article.habitats.block2.body" = "Kolam, sungai, dan padang rumput yang lembap menjadi tuan rumah bagi spesialis seperti capung, damselflies, dan banyak kumbang. Perbatasan antara tanah dan air – alang-alang, tepian sungai yang berlumpur – seringkali merupakan zona terkaya. Amati dari kejauhan terlebih dahulu agar tidak mengganggu serangga yang sedang istirahat.";
"home.article.photography.block1.title" = "Cahaya dan jarak";
"home.article.photography.block1.body" = "Sinar matahari yang tersebar atau naungan terbuka memberikan penerangan yang merata tanpa bayangan yang tajam. Dapatkan jarak yang cukup dekat untuk memenuhi bingkai, namun hindari membuat bayangan Anda sendiri melintasi subjek. Reflektor kecil atau kartu putih dapat mengangkat detail di dalam ceruk bunga atau kulit kayu.";
"home.article.photography.block2.title" = "Kesabaran dan rasa hormat";
"home.article.photography.block2.body" = "Biarkan serangga menetap daripada mengejarnya. Mode burst membantu mengatasi selebaran yang gelisah. Jika Anda menggunakan flash, buat sesinya singkat dan jangan pernah mengarahkannya langsung ke mata vertebrata di sekitar. Setelah selesai, tinggalkan habitat seperti yang Anda temukan.";

