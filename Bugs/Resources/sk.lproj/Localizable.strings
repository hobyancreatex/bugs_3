/* Home — articles */
"home.articles_section_title" = "Užitočné články";
"home.article.identify.title" = "Ako poznáme hmyz?";
"home.article.identify.subtitle" = "Základné znaky a nástroje, ktoré pomáhajú rozlíšiť druhy na poli alebo od fotografie.";
"home.article.habitats.title" = "Kde žije hmyz";
"home.article.habitats.subtitle" = "Od pôdy a lístia až po kvety a vodu – typické biotopy, ktoré môžete bezpečne preskúmať.";
"home.article.photography.title" = "Makro fotografie bez stresu";
"home.article.photography.subtitle" = "Svetlo, vzdialenosť a trpezlivosť: krátke tipy pre jasnejšie snímky malých objektov.";
"home.article.identify.block1.title" = "Na čo sa pozeráme ako prvé";
"home.article.identify.block1.body" = "Tvar tela, krídel, tykadiel a nôh často na prvý pohľad zužuje poradie hmyzu. Farebné vzory pomáhajú, ale líšia sa v rámci druhu – kombinujte ich s veľkosťou, držaním tela a správaním. Ak je to možné, všimnite si, kde ste hmyz videli: hostiteľská rastlina, povrch pôdy alebo okraj vody, to všetko pridáva kontext.";
"home.article.identify.block2.title" = "Z fotografie";
"home.article.identify.block2.body" = "Ostrý, dobre osvetlený obraz zakaždým prekoná rozmazaný. Zachyťte pohľad zhora a ak môžete, tak aj bočný profil. Zahrňte zmysel pre mierku (mincu alebo prst), keď na veľkosti záleží. Niekoľko uhlov znižuje dohady, keď sú značky jemné alebo skryté pod zloženými krídlami.";
"home.article.habitats.block1.title" = "Vrstvy biotopu";
"home.article.habitats.block1.body" = "Hmyz využíva vertikálny priestor: baldachýn, podrast, podstielku, štrbiny kôry a pôdu. Otáčanie polena alebo dvíhanie kameňa odhaľuje iné spoločenstvo ako kvet na plnom slnku. Pohybujte sa pomaly a vymeňte kryty, aby mikrobiotopy zostali nedotknuté.";
"home.article.habitats.block2.title" = "Voda a okraje";
"home.article.habitats.block2.body" = "Rybníky, potoky a vlhké lúky sú hostiteľmi špecialistov, ako sú vážky, motýlice a mnohé chrobáky. Hranica medzi pevninou a vodou – trstina, bahnité brehy – je často najbohatšou zónou. Najskôr pozorujte z diaľky, aby ste sa vyhli rušivému odpočinku hmyzu.";
"home.article.photography.block1.title" = "Svetlo a vzdialenosť";
"home.article.photography.block1.body" = "Rozptýlené denné svetlo alebo otvorený tieň poskytujú rovnomerné osvetlenie bez ostrých tieňov. Priblížte sa dostatočne blízko, aby ste vyplnili rám, ale vyhnite sa vrhaniu vlastného tieňa na objekt. Malý reflektor alebo biela karta môže zdvihnúť detaily v hlbokých výklenkoch kvetov alebo kôry.";
"home.article.photography.block2.title" = "Trpezlivosť a rešpekt";
"home.article.photography.block2.body" = "Nechajte hmyz usadiť sa namiesto toho, aby ste ho prenasledovali. Burst režim pomáha pri plachých letákoch. Ak používate blesk, udržiavajte krátke relácie a nikdy ním nemierte priamo do očí stavovcov v okolí. Keď skončíte, nechajte biotop tak, ako ste ho našli.";

