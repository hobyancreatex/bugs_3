/* Home — articles */
"home.articles_section_title" = "Articoli utili";
"home.article.identify.title" = "Come identifichiamo gli insetti?";
"home.article.identify.subtitle" = "Segni e strumenti di base che aiutano a distinguere le specie sul campo o da una foto.";
"home.article.habitats.title" = "Dove vivono gli insetti";
"home.article.habitats.subtitle" = "Dal terreno e dai rifiuti di foglie ai fiori e all'acqua: habitat tipici che puoi esplorare in sicurezza.";
"home.article.photography.title" = "Foto macro senza stress";
"home.article.photography.subtitle" = "Luce, distanza e pazienza: brevi consigli per foto più nitide di piccoli soggetti.";
"home.article.identify.block1.title" = "Quello che guardiamo per primo";
"home.article.identify.block1.body" = "La forma del corpo, delle ali, delle antenne e delle zampe spesso restringe a colpo d'occhio l'ordine degli insetti. I modelli di colore aiutano, ma variano all’interno della specie: combinali con dimensioni, postura e comportamento. Quando possibile, annota dove hai visto l'insetto: pianta ospite, superficie del suolo o bordo dell'acqua, tutti elementi che aggiungono contesto.";
"home.article.identify.block2.title" = "Da una foto";
"home.article.identify.block2.body" = "Un'immagine nitida e ben illuminata batte ogni volta un'immagine sfocata. Cattura la vista dall'alto e, se puoi, il profilo laterale. Includi un senso di scala (una moneta o un dito) quando le dimensioni contano. Diverse angolazioni riducono le congetture quando i segni sono sottili o nascosti sotto le ali piegate.";
"home.article.habitats.block1.title" = "Strati di un habitat";
"home.article.habitats.block1.body" = "Gli insetti utilizzano lo spazio verticale: la chioma, il sottobosco, la lettiera delle foglie, le fessure della corteccia e il suolo. Girare un tronco o sollevare una pietra rivela una comunità diversa da quella di un capolino in pieno sole. Muoviti lentamente e sostituisci le coperture in modo che i microhabitat rimangano intatti.";
"home.article.habitats.block2.title" = "Acqua e bordi";
"home.article.habitats.block2.body" = "Stagni, ruscelli e prati umidi ospitano specialisti come libellule, damigelle e molti coleotteri. Il confine tra terra e acqua – canneti, rive fangose ​​– è spesso la zona più ricca. Osservare prima da lontano per evitare di disturbare gli insetti che riposano.";
"home.article.photography.block1.title" = "Luce e distanza";
"home.article.photography.block1.body" = "La luce diurna diffusa o l'ombra aperta forniscono un'illuminazione uniforme senza ombre nette. Avvicinati abbastanza da riempire l'inquadratura, ma evita di proiettare la tua ombra sul soggetto. Un piccolo riflettore o un cartoncino bianco possono evidenziare i dettagli nei profondi recessi dei fiori o della corteccia.";
"home.article.photography.block2.title" = "Pazienza e rispetto";
"home.article.photography.block2.body" = "Lascia che gli insetti si stabiliscano invece di inseguirli. La modalità Burst aiuta con i volantini ombrosi. Se usi il flash, mantieni le sessioni brevi e non puntarlo mai direttamente negli occhi dei vertebrati vicini. Quando hai finito, lascia l'habitat come lo hai trovato.";

