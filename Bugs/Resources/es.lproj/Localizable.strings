/* Home — articles */
"home.articles_section_title" = "Artículos útiles";
"home.article.identify.title" = "¿Cómo identificamos los insectos?";
"home.article.identify.subtitle" = "Señales y herramientas básicas que ayudan a diferenciar las especies en el campo o a partir de una fotografía.";
"home.article.habitats.title" = "donde viven los insectos";
"home.article.habitats.subtitle" = "Desde tierra y hojarasca hasta flores y agua: hábitats típicos que puedes explorar de forma segura.";
"home.article.photography.title" = "Fotografías macro sin estrés";
"home.article.photography.subtitle" = "Luz, distancia y paciencia: breves consejos para obtener fotografías más claras de sujetos pequeños.";
"home.article.identify.block1.title" = "Lo que miramos primero";
"home.article.identify.block1.body" = "La forma del cuerpo, las alas, las antenas y las patas a menudo delimitan el orden de los insectos de un vistazo. Los patrones de color ayudan, pero varían dentro de la especie: combínalos con el tamaño, la postura y el comportamiento. Cuando sea posible, observe dónde vio el insecto: la planta huésped, la superficie del suelo o el borde del agua agregan contexto.";
"home.article.identify.block2.title" = "De una foto";
"home.article.identify.block2.body" = "Una imagen nítida y bien iluminada siempre supera a una borrosa. Capture la vista superior y, si puede, el perfil lateral. Incluya un sentido de escala (una moneda o su dedo) cuando el tamaño importe. Varios ángulos reducen las conjeturas cuando las marcas son sutiles u ocultas bajo las alas plegadas.";
"home.article.habitats.block1.title" = "Capas de un hábitat";
"home.article.habitats.block1.body" = "Los insectos utilizan el espacio vertical: dosel, sotobosque, hojarasca, grietas de la corteza y suelo. Girar un tronco o levantar una piedra revela una comunidad diferente a la de una flor a pleno sol. Muévase lentamente y reemplace las cubiertas para que los microhábitats permanezcan intactos.";
"home.article.habitats.block2.title" = "Agua y bordes";
"home.article.habitats.block2.body" = "En estanques, arroyos y praderas húmedas viven especies como libélulas, caballitos del diablo y muchos escarabajos. La frontera entre la tierra y el agua (juncos, orillas fangosas) es a menudo la zona más rica. Observe primero desde la distancia para evitar molestar a los insectos en reposo.";
"home.article.photography.block1.title" = "Luz y distancia";
"home.article.photography.block1.body" = "La luz diurna difusa o la sombra abierta brindan una iluminación uniforme sin sombras marcadas. Acércate lo suficiente como para llenar el encuadre, pero evita proyectar tu propia sombra sobre el sujeto. Un pequeño reflector o una tarjeta blanca pueden resaltar detalles en rincones profundos de flores o cortezas.";
"home.article.photography.block2.title" = "Paciencia y respeto.";
"home.article.photography.block2.body" = "Deje que los insectos se instalen en lugar de perseguirlos. El modo ráfaga ayuda con los voladores asustadizos. Si utiliza flash, mantenga las sesiones breves y nunca apunte directamente a los ojos de los vertebrados cercanos. Cuando hayas terminado, deja el hábitat tal como lo encontraste.";

