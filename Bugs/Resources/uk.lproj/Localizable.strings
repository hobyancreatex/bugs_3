/* Home — articles */
"home.articles_section_title" = "Корисні статті";
"home.article.identify.title" = "Як ми розпізнаємо комах?";
"home.article.identify.subtitle" = "Основні ознаки та інструменти, які допомагають розрізняти види в полі або на фото.";
"home.article.habitats.title" = "Де живуть комахи";
"home.article.habitats.subtitle" = "Від ґрунту та листя до квітів і води — типові середовища існування, які ви можете досліджувати безпечно.";
"home.article.photography.title" = "Макро фото без стресу";
"home.article.photography.subtitle" = "Світло, відстань і терпіння: короткі поради для отримання чіткіших зображень маленьких об’єктів.";
"home.article.identify.block1.title" = "На що дивимося спочатку";
"home.article.identify.block1.body" = "Форма тіла, крил, вусиків і ніг часто з першого погляду звужує ряд комах. Кольорові візерунки допомагають, але вони відрізняються в межах виду — поєднуйте їх із розміром, поставою та поведінкою. Якщо можливо, запам’ятайте, де ви бачили комаху: рослина-господар, поверхня ґрунту чи край води – все це додає контекст.";
"home.article.identify.block2.title" = "З фото";
"home.article.identify.block2.body" = "Чітке, добре освітлене зображення щоразу перевершує розмите. Зніміть вид зверху і, якщо можете, профіль збоку. Включайте відчуття масштабу (монета або ваш палець), коли розмір має значення. Кілька кутів зменшують здогадки, коли маркування тонкі або приховані під складеними крилами.";
"home.article.habitats.block1.title" = "Шари середовища існування";
"home.article.habitats.block1.body" = "Комахи використовують вертикальний простір: полог, підлісок, листовий опад, тріщини кори та ґрунт. Повертаючи колоду чи піднімаючи камінь, можна виявити іншу спільноту, ніж голова квітки на сонці. Рухайтесь повільно та замінюйте кришки, щоб мікрожитла залишалися недоторканими.";
"home.article.habitats.block2.title" = "Вода і краї";
"home.article.habitats.block2.body" = "Ставки, струмки та вологі луки є домом для таких спеціалістів, як бабки, бабки та багато жуків. Кордон між землею та водою — очерет, мулисті береги — часто є найбагатшою зоною. Спочатку спостерігайте здалеку, щоб не турбувати відпочиваючих комах.";
"home.article.photography.block1.title" = "Світло і відстань";
"home.article.photography.block1.body" = "Розсіяне денне світло або відкрита тінь дає рівномірне освітлення без різких тіней. Підійдіть достатньо близько, щоб заповнити кадр, але не відкидайте власну тінь на об’єкт. Маленький відбивач або біла карта можуть підняти деталь у глибоких заглибленнях квітів або кори.";
"home.article.photography.block2.title" = "Терпіння і повага";
"home.article.photography.block2.body" = "Нехай комахи осідають, а не переслідують їх. Режим серійної зйомки допомагає з плачевними листівками. Якщо ви використовуєте спалах, зробіть сеанси короткими та ніколи не спрямовуйте його прямо в очі хребетним поблизу. Коли ви закінчите, залиште місце проживання таким, яким ви його знайшли.";

