/* Home — articles */
"home.articles_section_title" = "Nyttige artikler";
"home.article.identify.title" = "Hvordan identifiserer vi insekter?";
"home.article.identify.subtitle" = "Grunnleggende skilt og verktøy som hjelper til med å skille arter fra hverandre i felten eller fra et bilde.";
"home.article.habitats.title" = "Hvor insekter lever";
"home.article.habitats.subtitle" = "Fra jord og bladstrø til blomster og vann - typiske habitater du kan utforske trygt.";
"home.article.photography.title" = "Makrobilder uten stress";
"home.article.photography.subtitle" = "Lys, avstand og tålmodighet: korte tips for klarere bilder av små motiver.";
"home.article.identify.block1.title" = "Hva vi ser på først";
"home.article.identify.block1.body" = "Formen på kroppen, vinger, antenner og ben begrenser ofte rekkefølgen av insekter på et øyeblikk. Fargemønstre hjelper, men de varierer innen arter – kombiner dem med størrelse, holdning og oppførsel. Når det er mulig, legg merke til hvor du så insektet: vertsplante, jordoverflate eller vannkant legger alle til kontekst.";
"home.article.identify.block2.title" = "Fra et bilde";
"home.article.identify.block2.body" = "Et skarpt, godt opplyst bilde slår et uskarpt bilde hver gang. Fang toppvisningen og, hvis du kan, sideprofilen. Ta med en følelse av skala (en mynt eller fingeren din) når størrelsen betyr noe. Flere vinkler reduserer gjetting når markeringer er subtile eller skjult under foldede vinger.";
"home.article.habitats.block1.title" = "Lag av et habitat";
"home.article.habitats.block1.body" = "Insekter bruker vertikal plass: baldakin, underhus, bladstrø, barksprekker og jord. Å snu en tømmerstokk eller løfte en stein avslører et annet fellesskap enn et blomsterhode i full sol. Beveg deg sakte og bytt deksler slik at mikrohabitater forblir intakte.";
"home.article.habitats.block2.title" = "Vann og kanter";
"home.article.habitats.block2.body" = "Dammer, bekker og fuktige enger er vert for spesialister som øyenstikkere, damselflies og mange biller. Grensen mellom land og vann - siv, gjørmete bredder - er ofte den rikeste sonen. Observer først på avstand for å unngå å forstyrre hvilende insekter.";
"home.article.photography.block1.title" = "Lys og avstand";
"home.article.photography.block1.body" = "Diffust dagslys eller åpen skygge gir jevn belysning uten harde skygger. Kom nær nok til å fylle rammen, men unngå å kaste din egen skygge over motivet. En liten refleks eller hvitt kort kan løfte detaljer i dype fordypninger av blomster eller bark.";
"home.article.photography.block2.title" = "Tålmodighet og respekt";
"home.article.photography.block2.body" = "La insekter slå seg ned i stedet for å jage dem. Burst-modus hjelper med skitne flyers. Hvis du bruker blits, hold øktene korte og aldri pek den direkte inn i øynene til virveldyr i nærheten. Når du er ferdig, la habitatet være slik du fant det.";

