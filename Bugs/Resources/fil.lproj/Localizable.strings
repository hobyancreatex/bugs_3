/* Home — articles */
"home.articles_section_title" = "Mga kapaki-pakinabang na artikulo";
"home.article.identify.title" = "Paano natin nakikilala ang mga insekto?";
"home.article.identify.subtitle" = "Mga pangunahing palatandaan at tool na tumutulong sa pagtukoy ng mga species sa field o mula sa isang larawan.";
"home.article.habitats.title" = "Kung saan nakatira ang mga insekto";
"home.article.habitats.subtitle" = "Mula sa mga basura ng lupa at dahon hanggang sa mga bulaklak at tubig — mga tipikal na tirahan na maaari mong tuklasin nang ligtas.";
"home.article.photography.title" = "Mga macro na larawan nang walang stress";
"home.article.photography.subtitle" = "Banayad, distansya, at pasensya: maikling tip para sa mas malinaw na mga larawan ng maliliit na paksa.";
"home.article.identify.block1.title" = "Kung ano ang una nating tinitingnan";
"home.article.identify.block1.body" = "Ang hugis ng katawan, mga pakpak, antennae, at mga binti ay kadalasang nagpapaliit sa pagkakasunud-sunod ng mga insekto sa isang sulyap. Nakakatulong ang mga pattern ng kulay, ngunit iba-iba ang mga ito sa loob ng mga species — pagsamahin ang mga ito sa laki, postura, at pag-uugali. Kung maaari, tandaan kung saan mo nakita ang insekto: host plant, ibabaw ng lupa, o gilid ng tubig lahat ay nagdaragdag ng konteksto.";
"home.article.identify.block2.title" = "Mula sa isang larawan";
"home.article.identify.block2.body" = "Ang isang matalas, mahusay na naiilawan na imahe ay nakakatalo sa isang malabo sa bawat oras. Kunin ang tuktok na view at, kung magagawa mo, ang profile sa gilid. Magsama ng sense of scale (isang barya o iyong daliri) kapag mahalaga ang laki. Binabawasan ng ilang mga anggulo ang panghuhula kapag ang mga marka ay banayad o nakatago sa ilalim ng mga nakatiklop na pakpak.";
"home.article.habitats.block1.title" = "Mga layer ng isang tirahan";
"home.article.habitats.block1.body" = "Gumagamit ang mga insekto ng patayong espasyo: canopy, understory, leaf litter, bark crevices, at lupa. Ang pagpihit ng troso o pagbubuhat ng bato ay nagpapakita ng ibang komunidad kaysa sa ulo ng bulaklak sa buong araw. Dahan-dahang gumalaw at palitan ang mga takip upang manatiling buo ang mga microhabitat.";
"home.article.habitats.block2.title" = "Tubig at mga gilid";
"home.article.habitats.block2.body" = "Ang mga lawa, batis, at mamasa-masa na parang ay nagho-host ng mga espesyalista tulad ng mga tutubi, damselflies, at maraming salagubang. Ang hangganan sa pagitan ng lupa at tubig - mga tambo, maputik na mga bangko - ay madalas na pinakamayamang sona. Magmasid muna mula sa malayo upang maiwasan ang mga nakakagambalang mga insektong nagpapahinga.";
"home.article.photography.block1.title" = "Liwanag at distansya";
"home.article.photography.block1.body" = "Ang nagkakalat na liwanag ng araw o bukas na lilim ay nagbibigay ng pantay na pag-iilaw nang walang malupit na mga anino. Lumapit nang sapat upang punan ang frame, ngunit iwasang maglagay ng sarili mong anino sa kabuuan ng paksa. Ang isang maliit na reflector o puting card ay maaaring magtaas ng detalye sa malalalim na recess ng mga bulaklak o bark.";
"home.article.photography.block2.title" = "Pasensya at paggalang";
"home.article.photography.block2.body" = "Hayaang tumira ang mga insekto sa halip na habulin sila. Nakakatulong ang burst mode sa mga skittish flyers. Kung gumagamit ka ng flash, panatilihing maikli ang mga session at huwag itong direktang ituro sa mga mata ng mga vertebrates sa malapit. Kapag tapos ka na, umalis sa tirahan tulad ng nakita mo.";

