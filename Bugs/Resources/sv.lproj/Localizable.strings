/* Home — articles */
"home.articles_section_title" = "Användbara artiklar";
"home.article.identify.title" = "Hur identifierar vi insekter?";
"home.article.identify.subtitle" = "Grundläggande tecken och verktyg som hjälper till att skilja arter åt i fält eller från ett foto.";
"home.article.habitats.title" = "Där insekter lever";
"home.article.habitats.subtitle" = "Från jord och lövskräp till blommor och vatten - typiska livsmiljöer du kan utforska säkert.";
"home.article.photography.title" = "Makrobilder utan stress";
"home.article.photography.subtitle" = "Ljus, avstånd och tålamod: korta tips för tydligare bilder av små motiv.";
"home.article.identify.block1.title" = "Vad vi tittar på först";
"home.article.identify.block1.body" = "Kroppens form, vingar, antenner och ben begränsar ofta insekternas ordning med ett ögonkast. Färgmönster hjälper, men de varierar inom arten - kombinera dem med storlek, hållning och beteende. Om möjligt, notera var du såg insekten: värdväxt, jordyta eller vattenkant lägger alla till sammanhang.";
"home.article.identify.block2.title" = "Från ett foto";
"home.article.identify.block2.body" = "En skarp, väl upplyst bild slår en suddig varje gång. Fånga toppvyn och, om du kan, sidoprofilen. Inkludera en känsla av skala (ett mynt eller ditt finger) när storleken spelar roll. Flera vinklar minskar gissningar när markeringar är subtila eller dolda under vikta vingar.";
"home.article.habitats.block1.title" = "Lager av en livsmiljö";
"home.article.habitats.block1.body" = "Insekter använder vertikalt utrymme: baldakin, undervåning, lövströ, barkspringor och jord. Att vända en stock eller lyfta en sten avslöjar en annan gemenskap än ett blomhuvud i full sol. Rör dig långsamt och byt ut täcken så att mikrohabitat förblir intakta.";
"home.article.habitats.block2.title" = "Vatten och kanter";
"home.article.habitats.block2.body" = "Dammar, bäckar och fuktiga ängar är värd för specialister som trollsländor, damselflies och många skalbaggar. Gränsen mellan land och vatten - vass, leriga stränder - är ofta den rikaste zonen. Observera först på avstånd för att undvika att störa vilande insekter.";
"home.article.photography.block1.title" = "Ljus och avstånd";
"home.article.photography.block1.body" = "Diffust dagsljus eller öppen skugga ger jämn belysning utan hårda skuggor. Kom tillräckligt nära för att fylla ramen, men undvik att kasta din egen skugga över motivet. En liten reflex eller vitt kort kan lyfta detaljer i djupa fördjupningar av blommor eller bark.";
"home.article.photography.block2.title" = "Tålamod och respekt";
"home.article.photography.block2.body" = "Låt insekter bosätta sig istället för att jaga dem. Burst-läge hjälper till med skumma flygblad. Om du använder blixt, håll sessionerna korta och rikta den aldrig direkt in i ögonen på ryggradsdjur i närheten. När du är klar, lämna livsmiljön som du hittade den.";

