/* Home — articles */
"home.articles_section_title" = "Articles utiles";
"home.article.identify.title" = "Comment identifier les insectes ?";
"home.article.identify.subtitle" = "Des panneaux et des outils de base qui aident à distinguer les espèces sur le terrain ou à partir d'une photo.";
"home.article.habitats.title" = "Où vivent les insectes";
"home.article.habitats.subtitle" = "Du sol et des feuilles mortes aux fleurs et à l'eau : des habitats typiques que vous pouvez explorer en toute sécurité.";
"home.article.photography.title" = "Des photos macro sans stress";
"home.article.photography.subtitle" = "Lumière, distance et patience : petits conseils pour des photos plus claires de petits sujets.";
"home.article.identify.block1.title" = "Ce que nous regardons en premier";
"home.article.identify.block1.body" = "La forme du corps, des ailes, des antennes et des pattes permet souvent de déterminer d'un seul coup d'œil l'ordre des insectes. Les motifs de couleur sont utiles, mais ils varient selon les espèces : combinez-les avec la taille, la posture et le comportement. Lorsque cela est possible, notez où vous avez vu l'insecte : la plante hôte, la surface du sol ou le bord de l'eau ajoutent du contexte.";
"home.article.identify.block2.title" = "D'après une photo";
"home.article.identify.block2.body" = "Une image nette et bien éclairée bat à chaque fois une image floue. Capturez la vue de dessus et, si vous le pouvez, le profil latéral. Incluez une idée de l'échelle (une pièce de monnaie ou votre doigt) lorsque la taille compte. Plusieurs angles réduisent les incertitudes lorsque les marques sont subtiles ou cachées sous les ailes repliées.";
"home.article.habitats.block1.title" = "Couches d'un habitat";
"home.article.habitats.block1.body" = "Les insectes utilisent l’espace vertical : canopée, sous-étage, litière de feuilles, crevasses de l’écorce et sol. Tourner une bûche ou soulever une pierre révèle une communauté différente de celle d'un capitule en plein soleil. Déplacez-vous lentement et remplacez les couvertures pour que les microhabitats restent intacts.";
"home.article.habitats.block2.title" = "Eau et bords";
"home.article.habitats.block2.body" = "Les étangs, les ruisseaux et les prairies humides abritent des spécialistes tels que des libellules, des demoiselles et de nombreux coléoptères. La frontière entre la terre et l'eau — roseaux, berges boueuses — est souvent la zone la plus riche. Observez d’abord à distance pour éviter de déranger les insectes au repos.";
"home.article.photography.block1.title" = "Lumière et distance";
"home.article.photography.block1.body" = "La lumière du jour diffuse ou l'ombre ouverte donnent un éclairage uniforme sans ombres dures. Rapprochez-vous suffisamment pour remplir le cadre, mais évitez de projeter votre propre ombre sur le sujet. Un petit réflecteur ou une carte blanche peut rehausser les détails des profondeurs des fleurs ou de l'écorce.";
"home.article.photography.block2.title" = "Patience et respect";
"home.article.photography.block2.body" = "Laissez les insectes s’installer au lieu de les chasser. Le mode rafale aide les voyageurs capricieux. Si vous utilisez le flash, gardez les séances courtes et ne le dirigez jamais directement vers les yeux des vertébrés à proximité. Lorsque vous avez terminé, quittez l’habitat tel que vous l’avez trouvé.";

