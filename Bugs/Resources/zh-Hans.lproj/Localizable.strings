/* Home — articles */
"home.articles_section_title" = "有用的文章";
"home.article.identify.title" = "我们如何识别昆虫？";
"home.article.identify.subtitle" = "帮助在野外或照片中区分物种的基本标志和工具。";
"home.article.habitats.title" = "昆虫居住的地方";
"home.article.habitats.subtitle" = "从土壤和落叶到花朵和水——您可以安全探索的典型栖息地。";
"home.article.photography.title" = "微距照片无压力";
"home.article.photography.subtitle" = "光线、距离和耐心：关于拍摄小物体的清晰照片的简短提示。";
"home.article.identify.block1.title" = "我们首先看什么";
"home.article.identify.block1.body" = "身体、翅膀、触角和腿的形状往往一眼就能缩小昆虫的目数。颜色图案有所帮助，但它们因物种而异——将它们与体型、姿势和行为结合起来。如果可能，请记下您在哪里看到昆虫：寄主植物、土壤表面或水边都可以添加背景信息。";
"home.article.identify.block2.title" = "来自一张照片";
"home.article.identify.block2.body" = "清晰、光线充足的图像每次都会击败模糊的图像。拍摄俯视图，如果可以的话，拍摄侧面轮廓。当尺寸很重要时，请包括比例感（硬币或手指）。当标记很微妙或隐藏在折叠机翼下时，多个角度可以减少猜测。";
"home.article.habitats.block1.title" = "栖息地的层次";
"home.article.habitats.block1.body" = "昆虫利用垂直空间：树冠、林下、落叶层、树皮缝隙和土壤。转动一根木头或举起一块石头，可以揭示出与阳光下的花头不同的群落。缓慢移动并更换覆盖物，以保持微生境完好无损。";
"home.article.habitats.block2.title" = "水和边缘";
"home.article.habitats.block2.body" = "池塘、溪流和潮湿的草地上栖息着蜻蜓、豆娘和许多甲虫等专家。陆地和水域之间的边界——芦苇、泥泞的河岸——往往是最富饶的地区。先远距离观察，以免打扰休息的昆虫。";
"home.article.photography.block1.title" = "光与距离";
"home.article.photography.block1.body" = "漫射日光或开放式阴影可提供均匀的照明，而不会产生刺眼的阴影。距离足够近以填充整个框架，但避免将自己的阴影投射到拍摄对象上。小反光板或白卡可以提升花朵或树皮深处的细节。";
"home.article.photography.block2.title" = "耐心和尊重";
"home.article.photography.block2.body" = "让昆虫安定下来，而不是追逐它们。突发模式有助于处理不稳定的传单。如果您使用闪光灯，请保持简短，并且切勿将其直接对准附近脊椎动物的眼睛。完成后，让栖息地保持原样。";

