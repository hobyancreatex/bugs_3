/* Home — articles */
"home.articles_section_title" = "Nützliche Artikel";
"home.article.identify.title" = "Wie identifizieren wir Insekten?";
"home.article.identify.subtitle" = "Grundlegende Zeichen und Werkzeuge, die dabei helfen, Arten im Feld oder auf einem Foto zu unterscheiden.";
"home.article.habitats.title" = "Wo Insekten leben";
"home.article.habitats.subtitle" = "Von Erde und Laub bis hin zu Blumen und Wasser – typische Lebensräume, die Sie sicher erkunden können.";
"home.article.photography.title" = "Makrofotos ohne Stress";
"home.article.photography.subtitle" = "Licht, Abstand und Geduld: Kurze Tipps für klarere Bilder kleiner Motive.";
"home.article.identify.block1.title" = "Was wir uns zuerst ansehen";
"home.article.identify.block1.body" = "Die Form des Körpers, der Flügel, der Fühler und der Beine grenzt oft auf den ersten Blick die Ordnung der Insekten ein. Farbmuster helfen, aber sie variieren je nach Art – kombinieren Sie sie mit Größe, Haltung und Verhalten. Notieren Sie nach Möglichkeit, wo Sie das Insekt gesehen haben: Wirtspflanze, Bodenoberfläche oder Gewässerrand sorgen für Kontext.";
"home.article.identify.block2.title" = "Von einem Foto";
"home.article.identify.block2.body" = "Ein scharfes, gut beleuchtetes Bild übertrifft jedes Mal ein verschwommenes. Erfassen Sie die Draufsicht und, wenn möglich, das Seitenprofil. Beziehen Sie einen Maßstabssinn (eine Münze oder Ihren Finger) mit ein, wenn es auf die Größe ankommt. Mehrere Winkel reduzieren das Rätselraten, wenn die Markierungen subtil sind oder unter gefalteten Flügeln verborgen sind.";
"home.article.habitats.block1.title" = "Schichten eines Lebensraums";
"home.article.habitats.block1.body" = "Insekten nutzen den vertikalen Raum: Blätterdach, Unterholz, Laubstreu, Rindenspalten und Erde. Das Umdrehen eines Baumstamms oder das Anheben eines Steins offenbart eine andere Gemeinschaft als ein Blütenkopf in der vollen Sonne. Gehen Sie langsam vor und bringen Sie die Abdeckungen wieder an, damit die Mikrohabitate intakt bleiben.";
"home.article.habitats.block2.title" = "Wasser und Kanten";
"home.article.habitats.block2.body" = "Teiche, Bäche und feuchte Wiesen beherbergen Spezialisten wie Libellen, Libellen und viele Käfer. Die Grenze zwischen Land und Wasser – Schilf, schlammige Ufer – ist oft die reichste Zone. Beobachten Sie zunächst aus einiger Entfernung, um ruhende Insekten nicht zu stören.";
"home.article.photography.block1.title" = "Licht und Distanz";
"home.article.photography.block1.body" = "Diffuses Tageslicht oder offener Schatten sorgen für eine gleichmäßige Ausleuchtung ohne harte Schatten. Gehen Sie nah genug heran, um den Rahmen auszufüllen, aber vermeiden Sie es, Ihren eigenen Schatten auf das Motiv zu werfen. Ein kleiner Reflektor oder eine weiße Karte können Details in tiefen Vertiefungen von Blumen oder Rinde hervorheben.";
"home.article.photography.block2.title" = "Geduld und Respekt";
"home.article.photography.block2.body" = "Lassen Sie Insekten sesshaft werden, anstatt sie zu jagen. Der Burst-Modus hilft bei unruhigen Fliegern. Wenn Sie einen Blitz verwenden, halten Sie die Sitzungen kurz und richten Sie ihn niemals direkt auf die Augen von Wirbeltieren in der Nähe. Wenn Sie fertig sind, verlassen Sie den Lebensraum so, wie Sie ihn vorgefunden haben.";

