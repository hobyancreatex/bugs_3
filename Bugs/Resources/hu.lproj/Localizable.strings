/* Home — articles */
"home.articles_section_title" = "Hasznos cikkek";
"home.article.identify.title" = "Hogyan ismerjük fel a rovarokat?";
"home.article.identify.subtitle" = "Alapvető jelek és eszközök, amelyek segítenek megkülönböztetni a fajokat a szántóföldön vagy egy fényképről.";
"home.article.habitats.title" = "Ahol rovarok élnek";
"home.article.habitats.subtitle" = "A talajtól és az alomtól a virágokig és a vízig – tipikus élőhelyek, amelyeket biztonságosan felfedezhet.";
"home.article.photography.title" = "Makró fotók stressz nélkül";
"home.article.photography.subtitle" = "Fény, távolság és türelem: rövid tippek a kis témák tisztább képéhez.";
"home.article.identify.block1.title" = "Amit először megnézünk";
"home.article.identify.block1.body" = "A test alakja, a szárnyak, az antennák és a lábak gyakran egy pillantásra leszűkítik a rovarok sorrendjét. A színminták segítenek, de fajon belül változnak – kombinálja őket mérettel, testtartással és viselkedéssel. Ha lehetséges, jegyezze fel, hol látta a rovart: a tápnövény, a talaj felszíne vagy a víz széle, mind kontextust ad.";
"home.article.identify.block2.title" = "Egy fényképről";
"home.article.identify.block2.body" = "Az éles, jól megvilágított kép minden alkalommal felülmúlja az elmosódottat. Rögzítse a felülnézetet, és ha lehet, az oldalsó profilt. Ha a méret számít, használjon méretarányt (érmét vagy ujját). Számos szög csökkenti a találgatást, ha a jelölések finomak vagy összecsukott szárnyak alatt vannak elrejtve.";
"home.article.habitats.block1.title" = "Egy élőhely rétegei";
"home.article.habitats.block1.body" = "A rovarok függőleges teret használnak: lombkoronát, aljnövényzetet, avart, kéregréseket és talajt. Egy rönk forgatása vagy kő felemelése más közösséget tár fel, mint egy virágfej teljes napon. Mozogjon lassan, és helyezze vissza a takarót, hogy a mikroélőhelyek érintetlenek maradjanak.";
"home.article.habitats.block2.title" = "Víz és élek";
"home.article.habitats.block2.body" = "A tavak, a patakok és a nyirkos rétek olyan szakembereknek adnak otthont, mint a szitakötők, leánybogárok és sok bogarak. A szárazföld és a víz határa – nádasok, iszapos partok – gyakran a leggazdagabb zóna. Először távolról figyelje meg, hogy ne zavarja a pihenő rovarokat.";
"home.article.photography.block1.title" = "Fény és távolság";
"home.article.photography.block1.body" = "A szórt nappali fény vagy a nyitott árnyék egyenletes megvilágítást biztosít éles árnyékok nélkül. Menjen elég közel ahhoz, hogy kitöltse a keretet, de ne vessen saját árnyékát a témára. Egy kis fényvisszaverő vagy fehér kártya képes kiemelni a részleteket a virágok vagy a kéreg mély mélyedéseiben.";
"home.article.photography.block2.title" = "Türelem és tisztelet";
"home.article.photography.block2.body" = "Hagyja, hogy a rovarok megtelepedjenek ahelyett, hogy üldöznék őket. A sorozatfelvétel mód segít a sivár szórólapokon. Ha vakut használ, tartsa röviden az üléseket, és soha ne irányítsa közvetlenül a közelben lévő gerincesek szemébe. Ha végzett, hagyja az élőhelyet úgy, ahogy találta.";

