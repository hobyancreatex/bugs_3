/* Home — articles */
"home.articles_section_title" = "مقالات مفيدة";
"home.article.identify.title" = "كيف نتعرف على الحشرات؟";
"home.article.identify.subtitle" = "العلامات والأدوات الأساسية التي تساعد على التمييز بين الأنواع في الحقل أو من خلال الصورة.";
"home.article.habitats.title" = "حيث تعيش الحشرات";
"home.article.habitats.subtitle" = "من التربة وفضلات الأوراق إلى الزهور والمياه، يمكنك استكشاف الموائل النموذجية بأمان.";
"home.article.photography.title" = "صور ماكرو بدون ضغوط";
"home.article.photography.subtitle" = "الضوء والمسافة والصبر: نصائح قصيرة للحصول على صور أكثر وضوحًا للأهداف الصغيرة.";
"home.article.identify.block1.title" = "ما ننظر إليه أولا";
"home.article.identify.block1.body" = "غالبًا ما يؤدي شكل الجسم والأجنحة وقرون الاستشعار والأرجل إلى تضييق ترتيب الحشرات في لمحة. تساعد أنماط الألوان، لكنها تختلف باختلاف الأنواع، فهي تجمعها مع الحجم والوضعية والسلوك. عندما يكون ذلك ممكنًا، لاحظ المكان الذي رأيت فيه الحشرة: النبات المضيف، أو سطح التربة، أو حافة الماء، كلها تضيف سياقًا.";
"home.article.identify.block2.title" = "من الصورة";
"home.article.identify.block2.body" = "الصورة الحادة والمضاءة جيدًا تتفوق على الصورة الباهتة في كل مرة. التقط المنظر العلوي، وإذا أمكن، التقط الملف الجانبي. قم بتضمين إحساس بالحجم (عملة معدنية أو إصبعك) عندما يكون الحجم مهمًا. تعمل الزوايا المتعددة على تقليل التخمين عندما تكون العلامات خفية أو مخفية تحت الأجنحة المطوية.";
"home.article.habitats.block1.title" = "طبقات الموائل";
"home.article.habitats.block1.body" = "تستخدم الحشرات المساحة الرأسية: المظلة، والطبقة السفلية، وفضلات الأوراق، وشقوق اللحاء، والتربة. إن تحويل جذع شجرة أو رفع حجر يكشف عن مجتمع مختلف عن رأس زهرة تحت أشعة الشمس الكاملة. تحرك ببطء واستبدل الأغطية حتى تظل الموائل الدقيقة سليمة.";
"home.article.habitats.block2.title" = "الماء والحواف";
"home.article.habitats.block2.body" = "تستضيف البرك والجداول والمروج الرطبة متخصصين مثل اليعسوب والدامسيل والعديد من الخنافس. غالبًا ما تكون الحدود بين الأرض والمياه - القصب والضفاف الموحلة - هي المنطقة الأكثر ثراءً. راقب من مسافة بعيدة أولاً لتجنب إزعاج الحشرات أثناء الراحة.";
"home.article.photography.block1.title" = "الضوء والمسافة";
"home.article.photography.block1.body" = "ضوء النهار المنتشر أو الظل المفتوح يعطي إضاءة متساوية بدون ظلال قاسية. اقترب بدرجة كافية لملء الإطار، لكن تجنب إلقاء ظلك على الموضوع. يمكن لعاكس صغير أو بطاقة بيضاء أن ترفع التفاصيل في التجاويف العميقة للزهور أو اللحاء.";
"home.article.photography.block2.title" = "الصبر والاحترام";
"home.article.photography.block2.body" = "دع الحشرات تستقر بدلاً من مطاردتها. يساعد وضع الاندفاع في النشرات المتقلبة. إذا كنت تستخدم الفلاش، فاجعل الجلسات قصيرة ولا توجهه مباشرة إلى أعين الفقاريات القريبة. عند الانتهاء، اترك الموطن كما وجدته.";

