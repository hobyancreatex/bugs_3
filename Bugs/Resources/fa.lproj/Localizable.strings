"home.articles_section_title" = "مقالات مفید";
"home.article.identify.title" = "چگونه حشرات را شناسایی کنیم؟";
"home.article.identify.subtitle" = "علائم و ابزارهای اساسی که به تشخیص گونه ها در میدان یا عکس کمک می کند.";
"home.article.habitats.title" = "جایی که حشرات زندگی می کنند";
"home.article.habitats.subtitle" = "از خاک و بستر برگ گرفته تا گل و آب - زیستگاه های معمولی که می توانید با خیال راحت کاوش کنید.";
"home.article.photography.title" = "عکس های ماکرو بدون استرس";
"home.article.photography.subtitle" = "نور، فاصله و صبر: نکات کوتاه برای تصاویر واضح تر از سوژه های کوچک.";
"home.article.identify.block1.title" = "آنچه در ابتدا نگاه می کنیم";
"home.article.identify.block1.body" = "شکل بدن، بال‌ها، شاخک‌ها و پاها اغلب در یک نگاه مرتبه حشرات را محدود می‌کند. الگوهای رنگ کمک می کند، اما آنها در گونه ها متفاوت هستند - آنها را با اندازه، وضعیت بدن و رفتار ترکیب کنید. در صورت امکان، توجه داشته باشید که حشره را کجا دیدید: گیاه میزبان، سطح خاک، یا لبه آب، همگی زمینه را اضافه می کنند.";
"home.article.identify.block2.title" = "از یک عکس";
"home.article.identify.block2.body" = "یک تصویر واضح و با نور خوب هر بار تصویری تار را شکست می دهد. نمای بالا و در صورت امکان از نمایه کناری عکس بگیرید. هنگامی که اندازه مهم است، حس مقیاس (یک سکه یا انگشت خود) را در نظر بگیرید. زمانی که نشانه‌ها در زیر بال‌های تا شده پنهان می‌شوند، چندین زاویه حدس و گمان را کاهش می‌دهند.";
"home.article.habitats.block1.title" = "لایه های یک زیستگاه";
"home.article.habitats.block1.body" = "حشرات از فضای عمودی استفاده می کنند: سایبان، زیر زمین، بستر برگ، شکاف پوست و خاک. چرخاندن یک کنده یا بلند کردن یک سنگ جامعه ای متفاوت از یک سر گل در آفتاب کامل را نشان می دهد. به آرامی حرکت کنید و روکش ها را جایگزین کنید تا میکروسکوپ ها دست نخورده بمانند.";
"home.article.habitats.block2.title" = "آب و لبه ها";
"home.article.habitats.block2.body" = "برکه ها، نهرها و چمنزارهای مرطوب میزبان متخصصانی مانند سنجاقک، سنجاقک و بسیاری از سوسک ها هستند. مرز بین خشکی و آب - نیزارها، کرانه های گل آلود - اغلب غنی ترین منطقه است. برای جلوگیری از مزاحمت حشرات در حال استراحت ابتدا از فاصله دور مشاهده کنید.";
"home.article.photography.block1.title" = "نور و فاصله";
"home.article.photography.block1.body" = "نور پراکنده روز یا سایه باز روشنایی یکنواخت را بدون سایه های خشن می دهد. آنقدر نزدیک شوید که کادر را پر کنید، اما از انداختن سایه خود روی سوژه خودداری کنید. یک بازتابنده کوچک یا کارت سفید می تواند جزئیات را در فرورفتگی های عمیق گل ها یا پوست بلند کند.";
"home.article.photography.block2.title" = "صبر و احترام";
"home.article.photography.block2.body" = "بگذارید حشرات به جای تعقیب آنها ساکن شوند. حالت پشت سر هم به آگهی‌های اسکیتی کمک می‌کند. اگر از فلاش استفاده می کنید، جلسات را کوتاه نگه دارید و هرگز آن را مستقیماً به چشمان مهره داران نزدیک نگیرید. وقتی کارتان تمام شد، زیستگاه را همانطور که پیدا کردید ترک کنید.";

