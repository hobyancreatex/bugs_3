/* Home — articles */
"home.articles_section_title" = "Makala muhimu";
"home.article.identify.title" = "Je, tunatambuaje wadudu?";
"home.article.identify.subtitle" = "Ishara na zana za kimsingi zinazosaidia kutofautisha spishi shambani au kutoka kwa picha.";
"home.article.habitats.title" = "Ambapo wadudu wanaishi";
"home.article.habitats.subtitle" = "Kutoka kwa udongo na majani hadi maua na maji - makazi ya kawaida unaweza kuchunguza kwa usalama.";
"home.article.photography.title" = "Picha za jumla bila mafadhaiko";
"home.article.photography.subtitle" = "Mwanga, umbali, na uvumilivu: vidokezo vifupi vya picha wazi za masomo madogo.";
"home.article.identify.block1.title" = "Tunachoangalia kwanza";
"home.article.identify.block1.body" = "Umbo la mwili, mbawa, antena, na miguu mara nyingi hupunguza utaratibu wa wadudu kwa mtazamo. Mitindo ya rangi husaidia, lakini inatofautiana kati ya spishi - ichanganye na saizi, mkao na tabia. Inapowezekana, kumbuka mahali ulipoona wadudu: mmea mwenyeji, uso wa udongo, au ukingo wa maji yote huongeza muktadha.";
"home.article.identify.block2.title" = "Kutoka kwa picha";
"home.article.identify.block2.body" = "Picha kali na yenye mwanga mzuri hushinda picha yenye ukungu kila wakati. Nasa mwonekano wa juu na, kama unaweza, wasifu wa kando. Jumuisha hisia ya mizani (sarafu au kidole chako) wakati saizi ni muhimu. Pembe kadhaa hupunguza kazi ya kubahatisha wakati alama ni ndogo au zimefichwa chini ya mbawa zilizokunjwa.";
"home.article.habitats.block1.title" = "Layers of a habitat";
"home.article.habitats.block1.body" = "Wadudu hutumia nafasi ya wima: dari, chini, takataka ya majani, nyufa za gome na udongo. Kugeuza logi au kuinua jiwe kunaonyesha jamii tofauti kuliko kichwa cha maua kwenye jua kamili. Sogeza polepole na ubadilishe vifuniko ili makazi madogo yabaki bila kubadilika.";
"home.article.habitats.block2.title" = "Maji na kingo";
"home.article.habitats.block2.body" = "Mabwawa, vijito na malisho yenye unyevunyevu hukaribisha wataalamu kama vile kereng’ende, damselflies na mbawakawa wengi. Mpaka kati ya ardhi na maji - mianzi, benki zenye matope - mara nyingi ndio eneo tajiri zaidi. Angalia kwa mbali kwanza ili kuepuka kuvuruga wadudu wanaopumzika.";
"home.article.photography.block1.title" = "Mwanga na umbali";
"home.article.photography.block1.body" = "Kueneza mchana au kivuli wazi hutoa hata mwanga bila vivuli vikali. Sogeza karibu vya kutosha ili kujaza fremu, lakini epuka kuweka kivuli chako kwenye mada. Kiakisi kidogo au kadi nyeupe inaweza kuinua maelezo katika mapumziko ya kina ya maua au gome.";
"home.article.photography.block2.title" = "Uvumilivu na heshima";
"home.article.photography.block2.body" = "Acha wadudu watulie badala ya kuwafukuza. Hali ya Kupasuka husaidia kwa vipeperushi vyema. Ikiwa unatumia mweko, fanya vipindi vifupi na usiwahi kuelekeza moja kwa moja kwenye macho ya wanyama wenye uti wa mgongo walio karibu. Ukimaliza, acha makazi kama ulivyoipata.";

