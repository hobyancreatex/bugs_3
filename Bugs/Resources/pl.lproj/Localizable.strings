/* Home — articles */
"home.articles_section_title" = "Przydatne artykuły";
"home.article.identify.title" = "Jak identyfikujemy owady?";
"home.article.identify.subtitle" = "Podstawowe znaki i narzędzia pomagające odróżnić gatunki w terenie lub na zdjęciu.";
"home.article.habitats.title" = "Gdzie żyją owady";
"home.article.habitats.subtitle" = "Od gleby i liści po kwiaty i wodę — typowe siedliska, które możesz bezpiecznie eksplorować.";
"home.article.photography.title" = "Zdjęcia makro bez stresu";
"home.article.photography.subtitle" = "Światło, odległość i cierpliwość: krótkie wskazówki dotyczące wyraźniejszych zdjęć małych obiektów.";
"home.article.identify.block1.title" = "Na co patrzymy w pierwszej kolejności";
"home.article.identify.block1.body" = "Kształt ciała, skrzydeł, czułków i nóg często już na pierwszy rzut oka zawęża kolejność owadów. Wzory kolorów są pomocne, ale różnią się w zależności od gatunku — połącz je z rozmiarem, postawą i zachowaniem. Jeśli to możliwe, zanotuj, gdzie widziałeś owada: roślina żywicielska, powierzchnia gleby lub brzeg wody – wszystko to dodaje kontekstu.";
"home.article.identify.block2.title" = "Ze zdjęcia";
"home.article.identify.block2.body" = "Ostry, dobrze oświetlony obraz za każdym razem wygrywa z rozmazanym. Uchwyć widok z góry i, jeśli to możliwe, profil boczny. Jeśli rozmiar ma znaczenie, uwzględnij poczucie skali (moneta lub palec). Kilka kątów zmniejsza ryzyko zgadywania, gdy oznaczenia są subtelne lub ukryte pod złożonymi skrzydłami.";
"home.article.habitats.block1.title" = "Warstwy siedliska";
"home.article.habitats.block1.body" = "Owady wykorzystują przestrzeń pionową: baldachim, podszyt, ściółkę z liści, szczeliny kory i glebę. Obracanie kłody lub podnoszenie kamienia ujawnia inną społeczność niż główka kwiatu w pełnym słońcu. Poruszaj się powoli i załóż osłony, aby mikrosiedliska pozostały nienaruszone.";
"home.article.habitats.block2.title" = "Woda i krawędzie";
"home.article.habitats.block2.body" = "Stawy, strumienie i wilgotne łąki goszczą specjalistów, takich jak ważki, samice i wiele chrząszczy. Granica lądu i wody – trzciny, błotniste brzegi – to często najbogatsza strefa. Najpierw obserwuj z daleka, aby uniknąć niepokojenia odpoczywających owadów.";
"home.article.photography.block1.title" = "Światło i dystans";
"home.article.photography.block1.body" = "Rozproszone światło dzienne lub otwarty cień zapewniają równomierne oświetlenie bez ostrych cieni. Podejdź wystarczająco blisko, aby wypełnić kadr, ale unikaj rzucania własnego cienia na obiekt. Mały reflektor lub biała kartka mogą uwydatnić szczegóły w głębokich zakamarkach kwiatów lub kory.";
"home.article.photography.block2.title" = "Cierpliwość i szacunek";
"home.article.photography.block2.body" = "Pozwól owadom osiedlić się, zamiast je gonić. Tryb serii pomaga przy płochliwych lotnikach. Jeśli używasz lampy błyskowej, sesje powinny być krótkie i nigdy nie kieruj jej bezpośrednio w oczy kręgowców w pobliżu. Kiedy skończysz, opuść siedlisko w takim stanie, w jakim je zastałeś.";

