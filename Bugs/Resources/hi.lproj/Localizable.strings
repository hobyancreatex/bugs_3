/* Home — articles */
"home.articles_section_title" = "उपयोगी लेख";
"home.article.identify.title" = "हम कीड़ों की पहचान कैसे करते हैं?";
"home.article.identify.subtitle" = "बुनियादी संकेत और उपकरण जो खेत में या फोटो से प्रजातियों को अलग बताने में मदद करते हैं।";
"home.article.habitats.title" = "जहां कीड़े रहते हैं";
"home.article.habitats.subtitle" = "मिट्टी और पत्ती के कूड़े से लेकर फूल और पानी तक - विशिष्ट आवास जिन्हें आप सुरक्षित रूप से देख सकते हैं।";
"home.article.photography.title" = "बिना तनाव के मैक्रो तस्वीरें";
"home.article.photography.subtitle" = "प्रकाश, दूरी और धैर्य: छोटे विषयों की स्पष्ट तस्वीरों के लिए संक्षिप्त युक्तियाँ।";
"home.article.identify.block1.title" = "हम पहले क्या देखते हैं";
"home.article.identify.block1.body" = "शरीर का आकार, पंख, एंटीना और पैर अक्सर एक नज़र में कीड़ों के क्रम को सीमित कर देते हैं। रंग पैटर्न मदद करते हैं, लेकिन वे प्रजातियों के भीतर भिन्न होते हैं - उन्हें आकार, मुद्रा और व्यवहार के साथ जोड़ते हैं। जब संभव हो, ध्यान दें कि आपने कीट को कहाँ देखा: मेजबान पौधा, मिट्टी की सतह, या पानी का किनारा सभी संदर्भ जोड़ते हैं।";
"home.article.identify.block2.title" = "एक फोटो से";
"home.article.identify.block2.body" = "एक तेज़, अच्छी रोशनी वाली छवि हर बार धुंधली छवि को मात देती है। शीर्ष दृश्य और, यदि आप कर सकते हैं, तो पार्श्व प्रोफ़ाइल कैप्चर करें। जब आकार मायने रखता है तो पैमाने की भावना (एक सिक्का या अपनी उंगली) शामिल करें। जब निशान सूक्ष्म होते हैं या मुड़े हुए पंखों के नीचे छिपे होते हैं तो कई कोण अनुमान लगाना कम कर देते हैं।";
"home.article.habitats.block1.title" = "आवास की परतें";
"home.article.habitats.block1.body" = "कीड़े ऊर्ध्वाधर स्थान का उपयोग करते हैं: चंदवा, अंडरस्टोरी, पत्ती कूड़े, छाल दरारें, और मिट्टी। लट्ठे को मोड़ने या पत्थर उठाने से पूर्ण सूर्य में फूल के सिर की तुलना में एक अलग समुदाय का पता चलता है। धीरे-धीरे आगे बढ़ें और कवर बदलें ताकि सूक्ष्म आवास बरकरार रहें।";
"home.article.habitats.block2.title" = "पानी और किनारा";
"home.article.habitats.block2.body" = "तालाब, नदियाँ और नम घास के मैदान ड्रैगनफ़्लाइज़, डैम्फ़्लाइज़ और कई बीटल जैसे विशेषज्ञों की मेजबानी करते हैं। ज़मीन और पानी के बीच की सीमा - नरकट, कीचड़ भरे किनारे - अक्सर सबसे समृद्ध क्षेत्र होता है। आराम कर रहे कीड़ों को परेशान करने से बचने के लिए पहले दूर से निरीक्षण करें।";
"home.article.photography.block1.title" = "प्रकाश और दूरी";
"home.article.photography.block1.body" = "विसरित दिन का प्रकाश या खुली छाया कठोर छाया के बिना भी समान रोशनी देती है। फ़्रेम को भरने के लिए पर्याप्त करीब आएँ, लेकिन विषय पर अपनी छाया डालने से बचें। एक छोटा परावर्तक या सफेद कार्ड फूलों या छाल के गहरे अंतराल में विवरण उठा सकता है।";
"home.article.photography.block2.title" = "धैर्य और सम्मान";
"home.article.photography.block2.body" = "कीड़ों का पीछा करने के बजाय उन्हें बसने दें। बर्स्ट मोड स्किटिश फ़्लायर्स के साथ मदद करता है। यदि आप फ़्लैश का उपयोग करते हैं, तो सत्र छोटा रखें और इसे सीधे पास के कशेरुकी जीवों की आँखों में न डालें। जब आपका काम पूरा हो जाए, तो निवास स्थान को वैसे ही छोड़ दें जैसा आपने पाया था।";

