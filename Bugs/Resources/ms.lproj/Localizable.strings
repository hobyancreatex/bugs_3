/* Home — articles */
"home.articles_section_title" = "Artikel yang berguna";
"home.article.identify.title" = "Bagaimanakah kita mengenal pasti serangga?";
"home.article.identify.subtitle" = "Tanda dan alatan asas yang membantu membezakan spesies di lapangan atau daripada foto.";
"home.article.habitats.title" = "Tempat serangga hidup";
"home.article.habitats.subtitle" = "Daripada sampah tanah dan daun kepada bunga dan air — habitat biasa anda boleh meneroka dengan selamat.";
"home.article.photography.title" = "Foto makro tanpa tekanan";
"home.article.photography.subtitle" = "Cahaya, jarak dan kesabaran: petua pendek untuk gambar subjek kecil yang lebih jelas.";
"home.article.identify.block1.title" = "Apa yang kita lihat dahulu";
"home.article.identify.block1.body" = "Bentuk badan, sayap, antena, dan kaki sering mengecilkan susunan serangga sepintas lalu. Corak warna membantu, tetapi ia berbeza dalam spesies — gabungkan dengan saiz, postur dan tingkah laku. Apabila boleh, perhatikan tempat anda melihat serangga itu: tumbuhan perumah, permukaan tanah atau tepi air semuanya menambah konteks.";
"home.article.identify.block2.title" = "Daripada sebuah foto";
"home.article.identify.block2.body" = "Imej yang tajam dan terang dengan baik mengalahkan imej kabur setiap kali. Tangkap paparan atas dan, jika anda boleh, profil sisi. Sertakan deria skala (syiling atau jari anda) apabila saiz penting. Beberapa sudut mengurangkan tekaan apabila tanda halus atau tersembunyi di bawah sayap terlipat.";
"home.article.habitats.block1.title" = "Lapisan habitat";
"home.article.habitats.block1.body" = "Serangga menggunakan ruang menegak: kanopi, lantai bawah, sampah daun, celah kulit kayu, dan tanah. Memusing kayu atau mengangkat batu mendedahkan komuniti yang berbeza daripada kepala bunga di bawah sinar matahari penuh. Bergerak perlahan-lahan dan gantikan penutup supaya mikrohabitat kekal utuh.";
"home.article.habitats.block2.title" = "Air dan tepi";
"home.article.habitats.block2.body" = "Kolam, sungai dan padang rumput lembap menjadi tuan rumah pakar seperti pepatung, damselflies dan banyak kumbang. Sempadan antara tanah dan air - buluh, tebing berlumpur - selalunya zon terkaya. Perhatikan dari jauh terlebih dahulu untuk mengelakkan gangguan serangga yang sedang berehat.";
"home.article.photography.block1.title" = "Cahaya dan jarak";
"home.article.photography.block1.body" = "Cahaya siang yang meresap atau teduhan terbuka memberikan pencahayaan yang sekata tanpa bayang-bayang yang keras. Dapatkan cukup dekat untuk mengisi bingkai, tetapi elakkan menghantar bayang anda sendiri merentasi subjek. Reflektor kecil atau kad putih boleh mengangkat butiran dalam ceruk bunga atau kulit kayu yang dalam.";
"home.article.photography.block2.title" = "Sabar dan hormat";
"home.article.photography.block2.body" = "Biarkan serangga mengendap dan bukannya mengejarnya. Mod letusan membantu dengan risalah gelisah. Jika anda menggunakan denyar, pastikan sesi pendek dan jangan sekali-kali menghalakannya terus ke mata vertebrata berdekatan. Apabila anda selesai, tinggalkan habitat seperti yang anda temui.";

