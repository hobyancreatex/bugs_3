/* Home — articles */
"home.articles_section_title" = "Hyödyllisiä artikkeleita";
"home.article.identify.title" = "Miten tunnistamme hyönteiset?";
"home.article.identify.subtitle" = "Peruskyltit ja työkalut, jotka auttavat erottamaan lajit pellolla tai valokuvasta.";
"home.article.habitats.title" = "Missä hyönteiset elävät";
"home.article.habitats.subtitle" = "Maaperästä ja lehtipeitteestä kukkiin ja veteen – tyypillisiä elinympäristöjä, joita voit tutkia turvallisesti.";
"home.article.photography.title" = "Makrokuvat ilman stressiä";
"home.article.photography.subtitle" = "Valo, etäisyys ja kärsivällisyys: lyhyitä vinkkejä selkeämpien kuvien saamiseksi pienistä kohteista.";
"home.article.identify.block1.title" = "Mitä katsomme ensin";
"home.article.identify.block1.body" = "Kehon muoto, siivet, antennit ja jalat rajoittavat usein hyönteisten järjestystä yhdellä silmäyksellä. Värikuviot auttavat, mutta ne vaihtelevat lajin sisällä – yhdistä ne kokoon, asentoon ja käyttäytymiseen. Jos mahdollista, merkitse muistiin, missä näit hyönteisen: isäntäkasvi, maan pinta tai veden reuna lisäävät kontekstia.";
"home.article.identify.block2.title" = "Valokuvasta";
"home.article.identify.block2.body" = "Terävä, hyvin valaistu kuva voittaa sumean joka kerta. Kuvaa ylänäkymä ja, jos mahdollista, sivuprofiili. Ota mukaan mittakaava (kolikko tai sormi), kun koolla on väliä. Useat kulmat vähentävät arvailua, kun merkinnät ovat hienovaraisia ​​tai piilossa taitettujen siipien alle.";
"home.article.habitats.block1.title" = "Elinympäristön kerrokset";
"home.article.habitats.block1.body" = "Hyönteiset käyttävät pystysuoraa tilaa: katos, aluskasvi, lehtipeite, kuoren rakoja ja maaperää. Tukin kääntäminen tai kiven nostaminen paljastaa erilaisen yhteisön kuin kukanpää täydessä auringossa. Liiku hitaasti ja vaihda kannet, jotta mikroelinympäristöt pysyvät ehjinä.";
"home.article.habitats.block2.title" = "Vesi ja reunat";
"home.article.habitats.block2.body" = "Lammet, purot ja kosteat niityt isännöivät asiantuntijoita, kuten sudenkorentoja, emäkärpäsiä ja monia kovakuoriaisia. Maan ja veden välinen raja - ruoko, mutaiset ranteet - on usein rikkain vyöhyke. Tarkkaile ensin kaukaa välttääksesi häiritsevät lepäävät hyönteiset.";
"home.article.photography.block1.title" = "Valo ja etäisyys";
"home.article.photography.block1.body" = "Hajanainen päivänvalo tai avoin varjo antaa tasaisen valaistuksen ilman karkeita varjoja. Mene tarpeeksi lähelle täyttääksesi kehyksen, mutta vältä omaa varjoasi heittämästä kohteeseen. Pieni heijastin tai valkoinen kortti voi nostaa yksityiskohtia kukkien tai kuoren syviin syvennyksiin.";
"home.article.photography.block2.title" = "Kärsivällisyys ja kunnioitus";
"home.article.photography.block2.body" = "Anna hyönteisten asettua niiden jahtaamisen sijaan. Sarjakuvaustila auttaa surkeiden lentolehtisten kanssa. Jos käytät salamaa, pidä istunnot lyhyinä äläkä koskaan osoita sitä suoraan lähellä olevien selkärankaisten silmiin. Kun olet valmis, jätä elinympäristö sellaisena kuin löysit sen.";

