/* Home — articles */
"home.articles_section_title" = "Užitečné články";
"home.article.identify.title" = "Jak poznáme hmyz?";
"home.article.identify.subtitle" = "Základní znaky a nástroje, které pomáhají rozlišit druhy na poli nebo od fotografie.";
"home.article.habitats.title" = "Kde žije hmyz";
"home.article.habitats.subtitle" = "Od půdy a listového odpadu po květiny a vodu – typická stanoviště, která můžete bezpečně prozkoumat.";
"home.article.photography.title" = "Makro fotografie bez stresu";
"home.article.photography.subtitle" = "Světlo, vzdálenost a trpělivost: krátké tipy pro jasnější snímky malých objektů.";
"home.article.identify.block1.title" = "Na co se díváme jako první";
"home.article.identify.block1.body" = "Tvar těla, křídla, tykadla a nohy často zužují pořadí hmyzu na první pohled. Barevné vzory pomáhají, ale liší se v rámci druhu – kombinujte je s velikostí, držením těla a chováním. Pokud je to možné, poznamenejte si, kde jste hmyz viděli: hostitelská rostlina, povrch půdy nebo okraj vody, to vše přidává kontext.";
"home.article.identify.block2.title" = "Z fotografie";
"home.article.identify.block2.body" = "Ostrý, dobře osvětlený obraz pokaždé překoná ten rozmazaný. Zachyťte pohled shora a, pokud můžete, boční profil. Pokud na velikosti záleží, použijte smysl pro měřítko (mince nebo prst). Několik úhlů snižuje dohady, když jsou značky jemné nebo skryté pod složenými křídly.";
"home.article.habitats.block1.title" = "Vrstvy stanoviště";
"home.article.habitats.block1.body" = "Hmyz využívá vertikální prostor: baldachýn, podrost, podestýlku, štěrbiny kůry a půdu. Otočení klády nebo zvednutí kamene odhaluje jiné společenství než květina na plném slunci. Pohybujte se pomalu a vyměňte kryty, aby mikrostanoviště zůstala nedotčená.";
"home.article.habitats.block2.title" = "Voda a okraje";
"home.article.habitats.block2.body" = "Rybníky, potoky a vlhké louky hostí specialisty, jako jsou vážky, motýlice a mnoho brouků. Hranice mezi zemí a vodou – rákosí, bahnité břehy – je často nejbohatší oblastí. Nejprve pozorujte z dálky, abyste nerušili odpočívající hmyz.";
"home.article.photography.block1.title" = "Světlo a vzdálenost";
"home.article.photography.block1.body" = "Rozptýlené denní světlo nebo otevřený stín poskytují rovnoměrné osvětlení bez ostrých stínů. Přibližte se dostatečně blízko, abyste zaplnili rámeček, ale vyhněte se vrhání vlastního stínu přes objekt. Malý reflektor nebo bílá kartička může zvednout detaily v hlubokých výklencích květin nebo kůry.";
"home.article.photography.block2.title" = "Trpělivost a respekt";
"home.article.photography.block2.body" = "Nechte hmyz usadit se místo toho, abyste ho honili. Burst režim pomáhá s plachými letáky. Pokud používáte blesk, udržujte relace krátké a nikdy jej nemiřte přímo do očí obratlovců v okolí. Až budete hotovi, opusťte stanoviště tak, jak jste jej našli.";

