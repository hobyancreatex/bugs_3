/* Home — articles */
"home.articles_section_title" = "দরকারী নিবন্ধ";
"home.article.identify.title" = "আমরা কিভাবে পোকামাকড় সনাক্ত করতে পারি?";
"home.article.identify.subtitle" = "মৌলিক চিহ্ন এবং সরঞ্জাম যা ক্ষেত্র বা ফটো থেকে প্রজাতিকে আলাদা করতে সাহায্য করে।";
"home.article.habitats.title" = "যেখানে পোকামাকড় বাস করে";
"home.article.habitats.subtitle" = "মাটি এবং পাতার আবর্জনা থেকে ফুল এবং জল - সাধারণ আবাসস্থল আপনি নিরাপদে অন্বেষণ করতে পারেন।";
"home.article.photography.title" = "চাপ ছাড়াই ম্যাক্রো ফটো";
"home.article.photography.subtitle" = "হালকা, দূরত্ব, এবং ধৈর্য: ছোট বিষয়ের স্পষ্ট ছবিগুলির জন্য ছোট টিপস।";
"home.article.identify.block1.title" = "আমরা কি প্রথম তাকান";
"home.article.identify.block1.body" = "শরীরের আকৃতি, ডানা, অ্যান্টেনা এবং পায়ে প্রায়ই এক নজরে পোকামাকড়ের ক্রম সংকুচিত হয়। রঙের নিদর্শনগুলি সাহায্য করে, তবে তারা প্রজাতির মধ্যে পরিবর্তিত হয় - আকার, ভঙ্গি এবং আচরণের সাথে তাদের একত্রিত করে। যখন সম্ভব, নোট করুন আপনি কোথায় কীটপতঙ্গ দেখেছেন: হোস্ট উদ্ভিদ, মাটির পৃষ্ঠ বা জলের প্রান্ত সবই প্রসঙ্গ যোগ করে।";
"home.article.identify.block2.title" = "একটি ছবি থেকে";
"home.article.identify.block2.body" = "একটি তীক্ষ্ণ, ভাল-আলোকিত ছবি প্রতিবার একটি ঝাপসা ছবিকে হারায়। উপরের দৃশ্যটি ক্যাপচার করুন এবং, যদি আপনি পারেন, পাশের প্রোফাইলটি। যখন আকার গুরুত্বপূর্ণ তখন স্কেলের অনুভূতি (একটি মুদ্রা বা আপনার আঙুল) অন্তর্ভুক্ত করুন। চিহ্নগুলি সূক্ষ্ম বা ভাঁজ করা ডানার নীচে লুকিয়ে থাকলে বেশ কয়েকটি কোণ অনুমানকে হ্রাস করে।";
"home.article.habitats.block1.title" = "আবাসস্থলের স্তর";
"home.article.habitats.block1.body" = "পোকামাকড় উল্লম্ব স্থান ব্যবহার করে: ক্যানোপি, আন্ডারস্টোরি, পাতার আবর্জনা, বাকল ফাটল এবং মাটি। একটি লগ বাঁকানো বা একটি পাথর উত্তোলন সম্পূর্ণ সূর্যের মধ্যে একটি ফুলের মাথার চেয়ে ভিন্ন সম্প্রদায়কে প্রকাশ করে। ধীরে ধীরে সরান এবং কভার প্রতিস্থাপন করুন যাতে মাইক্রোবাস অক্ষত থাকে।";
"home.article.habitats.block2.title" = "জল এবং প্রান্ত";
"home.article.habitats.block2.body" = "পুকুর, স্রোত এবং স্যাঁতসেঁতে তৃণভূমিতে বিশেষজ্ঞরা যেমন ড্রাগনফ্লাই, ড্যামসেলফ্লাই এবং অনেক পোকা থাকে। ভূমি এবং জলের মধ্যে সীমানা - খাগড়া, কর্দমাক্ত তীর - প্রায়শই সবচেয়ে ধনী অঞ্চল। বিশ্রামরত পোকামাকড়কে বিরক্ত না করার জন্য প্রথমে দূর থেকে পর্যবেক্ষণ করুন।";
"home.article.photography.block1.title" = "আলো এবং দূরত্ব";
"home.article.photography.block1.body" = "বিচ্ছুরিত দিনের আলো বা খোলা ছায়া কঠোর ছায়া ছাড়াই আলোকসজ্জা দেয়। ফ্রেম পূরণ করার জন্য যথেষ্ট কাছাকাছি যান, কিন্তু বিষয় জুড়ে আপনার নিজের ছায়া কাস্ট করা এড়ান। একটি ছোট প্রতিফলক বা সাদা কার্ড ফুল বা বাকলের গভীর ছিদ্রে বিস্তারিত তুলে ধরতে পারে।";
"home.article.photography.block2.title" = "ধৈর্য এবং সম্মান";
"home.article.photography.block2.body" = "পোকামাকড়কে তাড়া না করে বসতি স্থাপন করতে দিন। বার্স্ট মোড স্কিটিশ ফ্লায়ারদের সাহায্য করে। আপনি যদি ফ্ল্যাশ ব্যবহার করেন, সেশনগুলি সংক্ষিপ্ত রাখুন এবং কখনই এটিকে আশেপাশের মেরুদণ্ডী প্রাণীদের চোখে সরাসরি নির্দেশ করবেন না। আপনার কাজ শেষ হয়ে গেলে, আবাসস্থলটি আপনি যেমন পেয়েছেন তা ছেড়ে দিন।";

