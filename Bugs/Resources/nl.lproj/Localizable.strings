/* Home — articles */
"home.articles_section_title" = "Nuttige artikelen";
"home.article.identify.title" = "Hoe identificeren we insecten?";
"home.article.identify.subtitle" = "Basistekens en hulpmiddelen waarmee u soorten in het veld of vanaf een foto van elkaar kunt onderscheiden.";
"home.article.habitats.title" = "Waar insecten leven";
"home.article.habitats.subtitle" = "Van grond en bladafval tot bloemen en water: typische habitats die u veilig kunt verkennen.";
"home.article.photography.title" = "Macrofoto's zonder stress";
"home.article.photography.subtitle" = "Licht, afstand en geduld: korte tips voor duidelijkere foto's van kleine onderwerpen.";
"home.article.identify.block1.title" = "Waar we eerst naar kijken";
"home.article.identify.block1.body" = "Vorm van het lichaam, vleugels, antennes en poten bepalen vaak in één oogopslag de volgorde van insecten. Kleurpatronen helpen, maar ze variëren per soort – combineer ze met grootte, houding en gedrag. Noteer indien mogelijk waar je het insect hebt gezien: waardplant, bodemoppervlak of waterrand voegen allemaal context toe.";
"home.article.identify.block2.title" = "Van een foto";
"home.article.identify.block2.body" = "Een scherp, goed belicht beeld verslaat elke keer een wazig beeld. Leg het bovenaanzicht vast en, indien mogelijk, het zijprofiel. Voeg een gevoel voor schaal toe (een munt of je vinger) als de maat ertoe doet. Verschillende hoeken verminderen het giswerk wanneer de markeringen subtiel zijn of verborgen zijn onder gevouwen vleugels.";
"home.article.habitats.block1.title" = "Lagen van een habitat";
"home.article.habitats.block1.body" = "Insecten gebruiken verticale ruimte: bladerdak, ondergroei, bladafval, schorsspleten en aarde. Als je een boomstam omdraait of een steen optilt, zie je een andere gemeenschap dan een bloemhoofd in de volle zon. Beweeg langzaam en plaats de deksels terug, zodat microhabitats intact blijven.";
"home.article.habitats.block2.title" = "Water en randen";
"home.article.habitats.block2.body" = "Vijvers, beken en vochtige weilanden herbergen specialisten zoals libellen, waterjuffers en vele kevers. De grens tussen land en water – riet, modderige oevers – is vaak de rijkste zone. Observeer eerst vanaf een afstand om rustende insecten niet te storen.";
"home.article.photography.block1.title" = "Licht en afstand";
"home.article.photography.block1.body" = "Diffuus daglicht of open schaduw zorgt voor een gelijkmatige verlichting zonder harde schaduwen. Kom dichtbij genoeg om het kader te vullen, maar vermijd dat u uw eigen schaduw over het onderwerp werpt. Een kleine reflector of witte kaart kan details in diepe uitsparingen van bloemen of schors naar voren halen.";
"home.article.photography.block2.title" = "Geduld en respect";
"home.article.photography.block2.body" = "Laat insecten zich vestigen in plaats van ze te achtervolgen. Burst-modus helpt bij schichtige vliegers. Als u de flitser gebruikt, houd de sessies dan kort en richt deze nooit rechtstreeks in de ogen van gewervelde dieren in de buurt. Als je klaar bent, laat je het leefgebied achter zoals je het hebt aangetroffen.";

